local function clampSourceRootOffset(tendril, sourcePart, localOffset)
	local size = sourcePart.Size
	local xLimit = math.max(size.X * SOURCE_ROOT_SIDE_MAX_SCALE, 1.15)
	local yLimit = math.max(size.Y * SOURCE_ROOT_UP_MAX_SCALE, 1.15)
	local backMin = math.max(size.Z * SOURCE_ROOT_BACK_MIN, 0.25)
	local backMax = math.max(size.Z * 0.95, backMin + 0.1)

	local x = math.clamp(localOffset.X, -xLimit, xLimit)
	local y = math.clamp(localOffset.Y, -yLimit, yLimit)
	local z = math.clamp(localOffset.Z, backMin, backMax)

	return Vector3.new(x, y, z)
end

local conn
conn = RunService.Heartbeat:Connect(function()
	if not rig.Parent or not rigRoot.Parent then
		conn:Disconnect()
		if holder then
			holder:Destroy()
		end
		return
	end

	for i = #tendrils, 1, -1 do
		local t = tendrils[i]
		if t._dead or not t.parts[1] or not t.parts[1].Parent then
			table.remove(tendrils, i)
		end
	end

	local now = os.clock()
	local torsoCF = torsoPart.CFrame
	local torsoPos = torsoCF.Position
	local torsoRadius = math.max(torsoPart.Size.X, torsoPart.Size.Y, torsoPart.Size.Z) * 0.55

	local attackMode = currentAttackTargetPart and currentAttackTargetPart.Parent and currentAttackIntensity > 0

	for _, tendril in ipairs(tendrils) do
		local parts = tendril.parts
		local pointAttackMode = attackMode and tendril.attackEnabled
		local sourceCF = tendril.sourcePart and tendril.sourcePart.Parent and tendril.sourcePart.CFrame or torsoCF
		local localOffset = tendril.localOffset or Vector3.zero

		if tendril.sourcePart then
			local size = tendril.sourcePart.Size
			local sizeOffset = Vector3.new(
				size.X * tendril.markerSizeScale,
				size.Y * tendril.markerSizeScale,
				size.Z * tendril.markerSizeScale
			)

			localOffset = clampSourceRootOffset(tendril, tendril.sourcePart, localOffset + sizeOffset)
		end

		local rootPos = sourceCF:PointToWorldSpace(localOffset)
		local baseForward
		local upHint
		local retreatActive = tendril.retreatMode
			and tendril.retreatUntil > 0
			and now <= tendril.retreatUntil
			and tendril.retreatTargetPart
			and tendril.retreatTargetPart.Parent

		local attackInRange = true
		if pointAttackMode and tendril.attackRange then
			local targetPos = currentAttackTargetPart.Position
			attackInRange = (targetPos - rootPos).Magnitude <= tendril.attackRange
		end

		if retreatActive then
			local tipPos = tendril.retreatTargetPart.Position
			local awayFromMonster = safeUnit(rootPos - torsoPos)
			if awayFromMonster == Vector3.zero then
				awayFromMonster = -torsoCF.LookVector
			end

			local towardTip = safeUnit(tipPos - rootPos)
			baseForward = safeUnit((towardTip * 1.1) + (awayFromMonster * 1.25))
			if baseForward == Vector3.zero then
				baseForward = awayFromMonster
			end
			upHint = torsoCF.UpVector
		elseif tendril.sourcePart then
			if pointAttackMode and attackInRange then
				local targetDir = safeUnit(currentAttackTargetPart.Position - rootPos)
				if targetDir == Vector3.zero then
					targetDir = safeUnit(-sourceCF.LookVector)
				end

				local n1 = math.noise(tendril.seed + 101, now * 0.8, 0)
				local n2 = math.noise(tendril.seed + 202, 0, now * 0.8)
				local n3 = math.noise(tendril.seed + 303, now * 0.7, 0)

				local targetPull = 0.75 + currentAttackIntensity * 1.0
				local sphereMotion =
					sourceCF.RightVector * n1
					+ sourceCF.UpVector * n2
					+ (-sourceCF.LookVector) * n3
					+ targetDir * targetPull

				baseForward = safeUnit(sphereMotion)
				if baseForward == Vector3.zero then
					baseForward = targetDir
				end

				upHint = currentAttackTargetPart.CFrame.UpVector
			else
				local behindDir = -torsoCF.LookVector

				local sideNoise = math.noise(tendril.seed + 101, now * 0.8, 0)
				local upNoise = math.noise(tendril.seed + 202, 0, now * 0.8)
				local twistNoise = math.noise(tendril.seed + 303, now * 0.7, 0)

				local wild =
					behindDir * 0.8
					+ sourceCF.RightVector * (sideNoise * (0.55 * tendril.freeRoamScale))
					+ sourceCF.UpVector * (upNoise * (0.42 * tendril.freeRoamScale))
					+ (-sourceCF.LookVector) * (twistNoise * 0.35 * tendril.freeRoamScale)

				baseForward = safeUnit(wild)
				if baseForward == Vector3.zero then
					baseForward = behindDir
				end

				local distFromRig = (rootPos - torsoPos).Magnitude
				if distFromRig < torsoRadius * 1.05 then
					baseForward = safeUnit(baseForward:Lerp(behindDir, 0.9))
				end

				upHint = sourceCF.UpVector
			end
		else
			if pointAttackMode and attackInRange then
				local targetDir = safeUnit(currentAttackTargetPart.Position - torsoPos)
				baseForward = safeUnit(
					targetDir
						+ torsoCF.RightVector * tendril.sideSign * 0.25
						+ torsoCF.UpVector * tendril.liftSign * 0.18
				)
				if baseForward == Vector3.zero then
					baseForward = targetDir
				end
			else
				baseForward = safeUnit(
					(-torsoCF.LookVector * 0.78)
						+ (torsoCF.RightVector * tendril.sideSign * 0.22)
						+ (torsoCF.UpVector * tendril.liftSign * 0.12)
				)
			end
			upHint = torsoCF.UpVector
		end

		if baseForward == Vector3.zero then
			baseForward = -torsoCF.LookVector
		end

		local lungeScale = 1
		if pointAttackMode and attackInRange then
			lungeScale = 1 - (currentAttackIntensity * 0.9)
		end

		if retreatActive then
			lungeScale = 0.25
		end

		local sweep = math.sin(now * SWEEP_SPEED + tendril.phase) * MAX_SWEEP_ANGLE * tendril.sweepScale * lungeScale
		local swirl = math.clamp(
			math.noise(tendril.seed + 77, now * SWIRL_SPEED, 0) * MAX_SWIRL_ANGLE * tendril.swirlScale * lungeScale,
			-MAX_SWIRL_ANGLE,
			MAX_SWIRL_ANGLE
		)

		local roll = sweep + swirl * 0.35
		local rightDir = rotateAroundAxis(sourceCF.RightVector, baseForward, roll)
		local upDir = rotateAroundAxis(sourceCF.UpVector, baseForward, roll)

		local points = table.create(tendril.segmentCount)
		points[1] = rootPos

		local lastDir = safeUnit(baseForward * 0.72 + rightDir * (tendril.sideSign * 0.22) + upDir * (tendril.liftSign * 0.12))
		if lastDir == Vector3.zero then
			lastDir = baseForward
		end

		local lengthScale = tendril.lengthScale or 1

		for segmentIndex = 2, tendril.segmentCount do
			local alpha = (segmentIndex - 1) / (tendril.segmentCount - 1)
			local inv = 1 - alpha

			local n2 = math.noise(tendril.seed + 22, alpha * 2.4, now * (WIGGLE_SPEED * 0.92))
			local n3 = math.noise(tendril.seed + 33, now * 0.75, alpha * 5.2)
			local n4 = math.noise(tendril.seed + 44, now * 1.8, alpha * 7.0)

			local waveA = math.sin(now * (2.0 + alpha * 0.35) + tendril.phase + alpha * 10.0)
			local waveB = math.cos(now * (1.45 + alpha * 0.28) + tendril.phase * 1.3 + alpha * 6.0)
			local waveC = math.sin(now * 3.7 + tendril.phase * 0.7 + alpha * 13.0)
			local waveD = math.cos(now * 4.4 + tendril.phase * 1.9 + alpha * 9.0)

			local curl = safeUnit(lastDir:Cross(upDir))
			if curl == Vector3.zero then
				curl = rightDir
			end

			local sway = safeUnit(upDir:Cross(curl))
			if sway == Vector3.zero then
				sway = rightDir
			end

			local spread =
				baseForward * (0.95 - alpha * 0.25)
				+ rightDir * ((n2 * 1.15 + waveA * 1.45) * (0.55 + alpha * 1.8) + tendril.sideSign * 0.3)
				+ upDir * ((n3 * 1.05 + waveB * 1.25) * (0.5 + alpha * 1.5) + tendril.liftSign * 0.22)
				+ curl * (waveC * 0.72 * inv + n4 * 0.35)
				+ sway * (waveD * 0.38 * alpha)

			if pointAttackMode and attackInRange then
				local targetDir = safeUnit(currentAttackTargetPart.Position - (points[segmentIndex - 1] or rootPos))
				if targetDir ~= Vector3.zero then
					local attackBias = math.clamp((alpha - 0.2) / 0.8, 0, 1)
					local chaseStrength = (0.2 + currentAttackIntensity * 1.15) * attackBias
					spread = spread + targetDir * chaseStrength

					if attackBias > 0.1 then
						spread = spread:Lerp(targetDir, attackBias * currentAttackIntensity)
					end
				end
			end

			if tendril.sourcePart and not pointAttackMode and not retreatActive then
				local behindDir = -sourceCF.LookVector
				local roam =
					sourceCF.RightVector * math.sin(now * 1.7 + tendril.phase + alpha * 5.0)
					+ sourceCF.UpVector * math.cos(now * 1.45 + tendril.phase * 1.2 + alpha * 4.0)
					+ (-sourceCF.LookVector) * math.sin(now * 1.1 + tendril.phase * 0.8 + alpha * 6.0)

				spread = spread
					+ roam * (0.85 * tendril.freeRoamScale)
					+ behindDir * (0.65 * tendril.repelScale)

				if spread:Dot(behindDir) < 0 then
					spread = spread + behindDir * math.abs(spread:Dot(behindDir)) * 1.5
				end
			end

			if retreatActive then
				local tipPos = tendril.retreatTargetPart.Position
				local pullDir = safeUnit(tipPos - (points[segmentIndex - 1] or rootPos))
				if pullDir ~= Vector3.zero then
					spread = spread:Lerp(pullDir, 0.75)
				end
			end

			local desired = safeUnit(spread)
			if desired == Vector3.zero then
				desired = lastDir
			end

			local bend = 0.14 + alpha * 0.34
			if pointAttackMode and attackInRange then
				bend = math.clamp(bend + currentAttackIntensity * 0.5, 0.2, 0.95)
			end
			if retreatActive then
				bend = math.clamp(bend + 0.15, 0.2, 0.9)
			end

			local dir = safeUnit(lastDir:Lerp(desired, bend))
			if dir == Vector3.zero then
				dir = desired
			end

			local chaos =
				1
				+ math.sin(now * 1.3 + tendril.phase + alpha * 8.0) * STRETCH_AMOUNT
				+ math.sin(now * 5.8 + tendril.phase * 0.7 + alpha * 17.0) * 0.1
				+ math.noise(tendril.seed + 55, now * 0.7, alpha * 3.0) * 0.12

			if pointAttackMode and attackInRange then
				chaos = 1 + (chaos - 1) * (1 - currentAttackIntensity)
			end
			if retreatActive then
				chaos = 1 + (chaos - 1) * 0.5
			end

			local segmentScale = 1 + (math.sin(alpha * math.pi) * 0.12)
			local step = tendril.segmentSpacing * chaos * segmentScale * 0.98 * lengthScale

			points[segmentIndex] = points[segmentIndex - 1] + dir * step
			lastDir = dir
		end

		for segmentIndex, part in ipairs(parts) do
			local alpha = (segmentIndex - 1) / (tendril.segmentCount - 1)
			local thickness = (BASE_THICKNESS + (TIP_THICKNESS - BASE_THICKNESS) * alpha) * (tendril.thicknessScale or 1)
			thickness = math.max(thickness, TIP_THICKNESS)

			part.Size = Vector3.new(thickness, thickness, thickness)
			part.Color = tendril.color or Color3.fromRGB(0, 0, 0)
			part.CollisionGroup = TENDRIL_GROUP
			part.CanCollide = false
			part.CanTouch = false
			part.CanQuery = false

			if tendril.lockTipPart and tendril.lockTipPart.Parent and segmentIndex == tendril.segmentCount then
				local targetPos = tendril.lockTipPart.Position
				local prev = points[segmentIndex - 1] or points[segmentIndex - 2] or rootPos
				local dir = safeUnit(targetPos - prev)
				if dir == Vector3.zero then
					dir = safeUnit(tendril.lockTipPart.CFrame.LookVector)
				end
				if dir == Vector3.zero then
					dir = baseForward
				end
				part.CFrame = frameFromForward(targetPos, dir, tendril.lockTipPart.CFrame.UpVector)
			elseif segmentIndex == 1 then
				local rootDir = safeUnit(points[2] - points[1])
				if rootDir == Vector3.zero then
					rootDir = baseForward
				end
				part.CFrame = frameFromForward(points[1], rootDir, upHint)
			else
				local pos = points[segmentIndex]
				local prev = points[segmentIndex - 1]
				local dir = safeUnit(pos - prev)
				if dir == Vector3.zero then
					dir = baseForward
				end

				if tendril.lockTipPart and tendril.lockTipPart.Parent and segmentIndex >= tendril.segmentCount - 3 then
					local targetDir = safeUnit(tendril.lockTipPart.Position - prev)
					if targetDir ~= Vector3.zero then
						dir = safeUnit(dir:Lerp(targetDir, 0.85))
					end
				end

				local center = prev + dir * (tendril.segmentSpacing * 0.5)
				part.CFrame = frameFromForward(center, dir, upHint)
			end
		end
	end

	if attackMode and currentAttackTargetPart and currentAttackTargetPart.Parent then
		local dir = safeUnit(currentAttackTargetPart.Position - rigRoot.Position)
		if dir ~= Vector3.zero then
			npcHumanoid.WalkSpeed = 0
		end
	end
end)
