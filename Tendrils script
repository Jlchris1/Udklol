local function makePartSet(parts)
	local set = {}
	for _, part in ipairs(parts) do
		set[part] = true
	end
	return set
end

local function destroyConnectionsForParts(model, parts)
	local set = makePartSet(parts)

	for _, inst in ipairs(model:GetDescendants()) do
		if inst:IsA("Motor6D") or inst:IsA("Weld") or inst:IsA("ManualWeld") or inst:IsA("WeldConstraint") or inst:IsA("NoCollisionConstraint") then
			local p0 = inst.Part0
			local p1 = inst.Part1
			if (p0 and set[p0]) or (p1 and set[p1]) then
				inst:Destroy()
			end
		elseif inst:IsA("BallSocketConstraint") or inst:IsA("HingeConstraint") or inst:IsA("SpringConstraint") or inst:IsA("AlignPosition") or inst:IsA("AlignOrientation") then
			local a0 = inst.Attachment0
			local a1 = inst.Attachment1
			local p0 = a0 and a0.Parent
			local p1 = a1 and a1.Parent
			if (p0 and set[p0]) or (p1 and set[p1]) then
				inst:Destroy()
			end
		elseif inst:IsA("Attachment") then
			if set[inst.Parent] then
				inst:Destroy()
			end
		end
	end
end

