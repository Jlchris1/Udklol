local function slowlyBringVictimToMouth(targetModel, targetRoot, monsterHeadPart)
	if not targetModel or not targetRoot or not targetRoot.Parent then
		return
	end
	if not monsterHeadPart or not monsterHeadPart.Parent then
		return
	end

	setModelCollisionGroup(targetModel, NPC_GROUP)
	setModelCanCollide(targetModel, false)
	setModelCanQuery(targetModel, false)
	forcePlatformStand(targetModel)

	local feastTendrils = spawnPullPairTendrils(
		targetRoot,
		1,
		1,
		Vector3.new(0, torsoPart.Size.Y * 0.35, -(torsoPart.Size.Z * 0.5 + 1.2)),
		{
			thicknessScale = 1.18,
			lengthScale = 1.12,
			markerSizeScale = 0.2,
			sweepScale = 0.0,
			swirlScale = 0.0,
			freeRoamScale = 0,
			pairSpreadX = 1.55,
			pairSpreadY = 0.22,
			attackEnabled = true,
		}
	)

	local start = os.clock()

	while targetModel.Parent and targetRoot.Parent and monsterHeadPart.Parent do
		forcePlatformStand(targetModel)

		local distance = (targetRoot.Position - monsterHeadPart.Position).Magnitude
		local approachOffset = math.clamp(distance * 0.5, FINAL_DRAG_MIN_OFFSET, FINAL_DRAG_MAX_OFFSET)
		local mouthPos = monsterHeadPart.Position + monsterHeadPart.CFrame.LookVector * approachOffset + monsterHeadPart.CFrame.UpVector * 0.12

		targetRoot.Anchored = false
		targetRoot.CanCollide = false
		targetRoot.CanQuery = false
		targetRoot.AssemblyLinearVelocity = targetRoot.AssemblyLinearVelocity:Lerp((mouthPos - targetRoot.Position) * 2.5, 0.1)
		targetRoot.AssemblyAngularVelocity = targetRoot.AssemblyAngularVelocity:Lerp(Vector3.zero, 0.15)

		local pivot = targetModel:GetPivot()
		local desired = CFrame.new(mouthPos, monsterHeadPart.Position)
		targetModel:PivotTo(pivot:Lerp(desired, FINAL_DRAG_LERP))

		if isModelTouchingPart(targetModel, monsterHeadPart) or distance <= 1.05 or os.clock() - start >= FINAL_DRAG_TIME then
			break
		end

		task.wait(0.05)
	end

	for _, t in ipairs(feastTendrils) do
		destroyTendril(t)
	end
end

local function dragDetachedLimbToMouth(parts, monsterRoot, monsterHeadPart)
	if not parts or #parts == 0 then
		return
	end
	if not monsterRoot or not monsterRoot.Parent or not monsterHeadPart or not monsterHeadPart.Parent then
		return
	end

	local ordered = table.clone(parts)
	local rootPart = ordered[1]
	if not rootPart or not rootPart.Parent then
		return
	end

	for _, part in ipairs(ordered) do
		if part and part.Parent then
			part.Anchored = false
			part.CanCollide = true
			part.CanTouch = true
			part.CanQuery = true
			part.CollisionGroup = "Default"
			part.AssemblyLinearVelocity = Vector3.zero
			part.AssemblyAngularVelocity = Vector3.zero
		end
	end

	local offsets = {}
	local baseCF = rootPart.CFrame
	for i, part in ipairs(ordered) do
		offsets[i] = baseCF:ToObjectSpace(part.CFrame)
	end

	local stageCF = monsterRoot.CFrame * CFrame.new(
		0,
		torsoPart.Size.Y * 0.15,
		-(torsoPart.Size.Z * 1.1 + 2.8)
	)

	for i, part in ipairs(ordered) do
		part.CFrame = stageCF * offsets[i]
	end

	local carryTendrils = spawnPullPairTendrils(
		rootPart,
		1,
		1,
		Vector3.new(0, 0, 0),
		{
			thicknessScale = 1.0,
			lengthScale = 1.0,
			markerSizeScale = 0.12,
			sweepScale = 0.0,
			swirlScale = 0.0,
			freeRoamScale = 0,
			pairSpreadX = 0.95,
			pairSpreadY = 0.2,
			attackEnabled = true,
		}
	)

	local start = os.clock()
	local carryCF = stageCF

	while rootPart.Parent and monsterHeadPart.Parent do
		local distance = (rootPart.Position - monsterHeadPart.Position).Magnitude
		local approachOffset = math.clamp(distance * 0.5, FINAL_DRAG_MIN_OFFSET, FINAL_DRAG_MAX_OFFSET)
		local mouthPos = monsterHeadPart.Position + monsterHeadPart.CFrame.LookVector * approachOffset + monsterHeadPart.CFrame.UpVector * 0.12
		local desiredCF = CFrame.new(mouthPos, monsterHeadPart.Position)

		carryCF = carryCF:Lerp(desiredCF, FINAL_DRAG_LERP)

		for i, part in ipairs(ordered) do
			if part and part.Parent then
				part.CFrame = carryCF * offsets[i]
				part.AssemblyLinearVelocity = Vector3.zero
				part.AssemblyAngularVelocity = Vector3.zero
			end
		end

		if distance <= 1.05 or os.clock() - start >= FINAL_DRAG_TIME then
			break
		end

		task.wait(0.05)
	end

	for _, t in ipairs(carryTendrils) do
		destroyTendril(t)
	end

	for _, part in ipairs(ordered) do
		if part and part.Parent then
			part.Anchored = true
			part.CanCollide = true
			part.CanTouch = true
			part.CanQuery = false
			part.CFrame = CFrame.new(EAT_TELEPORT_POS)
			part.Anchored = false
		end
	end
end

local function eatLimbParts(parts, monsterRoot, monsterHeadPart)
	if #parts == 0 or not monsterRoot or not monsterRoot.Parent then
		return
	end

	local ordered = table.clone(parts)

	for _, part in ipairs(ordered) do
		part.Anchored = true
