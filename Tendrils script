local function calcSegmentCount(length, explicitSegmentAmount)
	if explicitSegmentAmount and explicitSegmentAmount >= 2 then
		return math.floor(explicitSegmentAmount)
	end
	return math.max(18, math.floor(length / BASE_SEGMENT_SPACING) + 1)
end

local function addTendril(spec)
	local length = spec.length or DEFAULT_TENDRIL_LENGTH
	local segmentCount = spec.segmentCount or calcSegmentCount(length, spec.segmentAmount)
	local segmentSpacing = length / math.max(segmentCount - 1, 1)

	local rootPart = createSphere(holder)
	rootPart.Name = "TendrilRoot"

	local chain = { rootPart }
	for _ = 2, segmentCount do
		table.insert(chain, createSphere(holder))
	end

	local tendril = {
		parts = chain,
		segmentCount = segmentCount,
		segmentSpacing = segmentSpacing,
		length = length,
		seed = math.random(1, 1000000) * (#tendrils + 1),
		phase = math.random() * math.pi * 2,
		sideSign = spec.sideSign or 1,
		liftSign = spec.liftSign or 1,
		sourcePart = spec.sourcePart,
		grabTargetPart = spec.grabTargetPart,
		localOffset = spec.localOffset or Vector3.zero,
		thicknessScale = spec.thicknessScale or 1,
		lengthScale = spec.lengthScale or 1,
		markerSizeScale = spec.markerSizeScale or 0.25,
		sweepScale = spec.sweepScale or 1,
		swirlScale = spec.swirlScale or 1,
		freeRoamScale = spec.freeRoamScale or 1,
		repelScale = spec.repelScale or 1,
		baseIndex = spec.baseIndex or 0,
		lockTipPart = spec.lockTipPart,
		attackEnabled = spec.attackEnabled ~= false,
		attackRange = spec.attackRange,
		color = spec.color or Color3.fromRGB(0, 0, 0),

		retreatMode = false,
		retreatUntil = 0,
		retreatTargetPart = nil,
		retreatMonsterRoot = nil,
	}

	table.insert(tendrils, tendril)
	return tendril
end

local function spawnAttackTendril(targetPart, sideSign, liftSign, localOffset, extra)
	extra = extra or {}
	return addTendril({
		localOffset = localOffset or Vector3.new((sideSign or 1) * 2.5, torsoPart.Size.Y * 0.5, 0),
		sideSign = sideSign or 1,
		liftSign = liftSign or 1,
		thicknessScale = extra.thicknessScale or 1.08,
		lengthScale = extra.lengthScale or 1.12,
		markerSizeScale = extra.markerSizeScale or 0.18,
		sweepScale = extra.sweepScale or 0.22,
		swirlScale = extra.swirlScale or 0.16,
		freeRoamScale = extra.freeRoamScale or 0.05,
		repelScale = extra.repelScale or 1,
		grabTargetPart = targetPart,
		lockTipPart = targetPart,
		attackEnabled = extra.attackEnabled ~= false,
		attackRange = extra.attackRange,
		color = extra.color,
		length = extra.length,
		segmentAmount = extra.segmentAmount,
	})
end

local function spawnPullPairTendrils(targetPart, sideSign, liftSign, localOffset, extra)
	extra = extra or {}
	local xSpread = extra.pairSpreadX or 1.35
	local ySpread = extra.pairSpreadY or 0.35
	local first = spawnAttackTendril(
		targetPart,
		sideSign,
		liftSign,
		localOffset + Vector3.new(xSpread, ySpread, 0),
		extra
	)
	local second = spawnAttackTendril(
		targetPart,
		-sideSign,
		-liftSign,
		localOffset + Vector3.new(-xSpread, -ySpread, 0),
		extra
	)
	return { first, second }
end

local function beginTendrilRetreat(tendrilList, limbRootPart, monsterRoot, duration)
	duration = duration or 1.0
	local expireAt = os.clock() + duration

	for _, t in ipairs(tendrilList) do
		if t then
			t.retreatMode = true
			t.retreatUntil = expireAt
			t.retreatTargetPart = limbRootPart
			t.retreatMonsterRoot = monsterRoot
			t.lockTipPart = limbRootPart
			t.freeRoamScale = 0
			t.sweepScale = 0
			t.swirlScale = 0
			t.repelScale = math.max(t.repelScale or 1, 1) * 1.8
		end
	end

	task.delay(duration + 0.05, function()
		for _, t in ipairs(tendrilList) do
			destroyTendril(t)
		end
	end)
end

