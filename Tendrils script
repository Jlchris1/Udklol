local function readChildTextValue(part, childName)
	local child = part:FindFirstChild(childName)
	if not child then
		return nil
	end

	if child:IsA("StringValue") then
		return child.Value
	elseif child:IsA("NumberValue") then
		return tostring(child.Value)
	elseif child:IsA("IntValue") then
		return tostring(child.Value)
	end

	return nil
end

local function readChildBoolValue(part, childName, defaultValue)
	local child = part:FindFirstChild(childName)
	if child and child:IsA("BoolValue") then
		return child.Value
	end
	return defaultValue
end

local function parseNumber(text)
	if text == nil then
		return nil
	end
	local n = tonumber(tostring(text):match("[-%d%.]+"))
	return n
end

local function parseColorValue(text)
	if not text then
		return nil
	end

	local nums = {}
	for n in tostring(text):gmatch("[-%d%.]+") do
		table.insert(nums, tonumber(n))
	end

	if #nums >= 3 then
		local r = math.clamp(nums[1], 0, 255)
		local g = math.clamp(nums[2], 0, 255)
		local b = math.clamp(nums[3], 0, 255)
		return Color3.fromRGB(r, g, b)
	end

	return nil
end

local function getPointIndex(name)
	local num = name:match("^" .. POINT_PREFIX .. "(%d+)$")
	if num then
		return tonumber(num)
	end
	if name == POINT_PREFIX then
		return 0
	end
	return nil
end

local function getPointSettingsFromPart(part)
	local cfg = {
		length = DEFAULT_TENDRIL_LENGTH,
		width = BASE_THICKNESS,
		swayIntensity = 1,
		color = Color3.fromRGB(0, 0, 0),
		segmentAmount = nil,
		attackEnabled = true,
		attackRange = nil,
	}

	local lenText = readChildTextValue(part, "Length")
	local widthText = readChildTextValue(part, "Width")
	local swayText = readChildTextValue(part, "SwayIntensity")
	local colorText = readChildTextValue(part, "Color")
	local segText = readChildTextValue(part, "SegmentAmount")
	local attackRangeText = readChildTextValue(part, "AttackRange")

	local len = parseNumber(lenText)
	local width = parseNumber(widthText)
	local sway = parseNumber(swayText)
	local seg = parseNumber(segText)
	local attackRange = parseNumber(attackRangeText)

	if len and len > 0 then
		cfg.length = len
	end

	if width and width > 0 then
		cfg.width = width
	end

	if sway and sway >= 0 then
		cfg.swayIntensity = sway
	end

	if seg and seg >= 2 then
		cfg.segmentAmount = math.floor(seg)
	end

	if attackRange and attackRange > 0 then
		cfg.attackRange = attackRange
	end

	local color = parseColorValue(colorText)
	if color then
		cfg.color = color
	end

	cfg.attackEnabled = readChildBoolValue(part, "Attack", true) ~= false

	return cfg
end

local function getPointSettingsFromOverride(partName, cfg)
	local override = POINT_CONFIG[partName]
	if override then
		for k, v in pairs(override) do
			cfg[k] = v
		end
	end
	return cfg
end

