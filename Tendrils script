local function safeUnit(v)
	if v.Magnitude < 0.001 then
		return Vector3.zero
	end
	return v.Unit
end

local function rotateAroundAxis(v, axis, angle)
	local a = safeUnit(axis)
	if a == Vector3.zero or math.abs(angle) < 1e-6 then
		return v
	end
	local c = math.cos(angle)
	local s = math.sin(angle)
	return v * c + a:Cross(v) * s + a * (a:Dot(v)) * (1 - c)
end

local function frameFromForward(pos, forwardDir, upHint)
	local forward = safeUnit(forwardDir)
	if forward == Vector3.zero then
		forward = Vector3.new(0, 0, -1)
	end

	local up = safeUnit(upHint or WORLD_UP)
	if up == Vector3.zero or math.abs(up:Dot(forward)) > 0.92 then
		up = WORLD_UP
		if math.abs(up:Dot(forward)) > 0.92 then
			up = WORLD_RIGHT
		end
	end

	local right = up:Cross(forward)
	if right.Magnitude < 0.001 then
		up = WORLD_RIGHT
		right = up:Cross(forward)
	end

	right = right.Unit
	local realUp = forward:Cross(right).Unit
	return CFrame.fromMatrix(pos, right, realUp, -forward)
end

local function soundId(id)
	return "rbxassetid://" .. tostring(id)
end

local function playSound(parent, id, volume, looped, playbackSpeed)
	if not parent then
		return nil
	end

	local s = Instance.new("Sound")
	s.SoundId = soundId(id)
	s.Volume = volume or 1
	s.Looped = looped or false
	s.PlaybackSpeed = playbackSpeed or 1
	s.RollOffMaxDistance = 90
	s.Parent = parent
	s:Play()

	if not looped then
		Debris:AddItem(s, 12)
	end

	return s
end

