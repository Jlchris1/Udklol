local doorTemplateCache = {}
local brokenDoorGuard = {}
local roomEntryMemory = {}
local roomPresenceState = {}
local sightState = {}

local function rememberDoorTemplate(doorModel)
	if not doorModel or not doorModel.Parent then
		return nil
	end

	if doorTemplateCache[doorModel] then
		return doorTemplateCache[doorModel]
	end

	local ok, clone = pcall(function()
		return doorModel:Clone()
	end)

	if not ok or not clone then
		return nil
	end

	local cache = {
		template = clone,
		pivot = doorModel:GetPivot(),
		parent = doorModel.Parent,
		source = doorModel,
		restored = false,
	}

	doorTemplateCache[doorModel] = cache
	return cache
end

local function restoreDoorTemplate(cache)
	if not cache or cache.restored then
		return
	end

	cache.restored = true
	local parent = cache.parent
	if not parent or not parent.Parent then
		parent = workspace
	end

	local clone = cache.template:Clone()
	clone.Parent = parent
	pcall(function()
		clone:PivotTo(cache.pivot)
	end)
end

local function zeroModelVelocities(model)
	for _, inst in ipairs(model:GetDescendants()) do
		if inst:IsA("BasePart") then
			inst.AssemblyLinearVelocity = Vector3.zero
			inst.AssemblyAngularVelocity = Vector3.zero
		end
	end
end

local function findCorePart(model)
	local preferred = getPartByNames(model, {
		"Door",
		"DoorPart",
		"Root",
		"Main",
		"Frame",
		"Center",
		"Top",
		"TopPart",
		"Above",
		"Header",
		"UpperPart",
		"Wall",
		"Front",
		"FrontWall",
	})
	if preferred then
		return preferred
	end

	return getModelRoot(model) or model:FindFirstChildWhichIsA("BasePart", true)
end

local function collectBreakableParts(rootModel, excludedModelNames)
	local excluded = {}
	if excludedModelNames then
		for _, child in ipairs(rootModel:GetDescendants()) do
			if child:IsA("Model") then
				for _, exName in ipairs(excludedModelNames) do
					if child.Name == exName then
						excluded[child] = true
					end
				end
			end
		end
	end

	local parts = {}
	for _, inst in ipairs(rootModel:GetDescendants()) do
		if inst:IsA("BasePart") then
			local skip = false
			for exModel in pairs(excluded) do
				if inst:IsDescendantOf(exModel) then
					skip = true
					break
				end
			end
			if not skip then
				table.insert(parts, inst)
			end
		end
	end

	return parts
end

local function applyDoorBreakSequence(rootModel, monsterRoot, opts)
	opts = opts or {}
	if not rootModel or not rootModel.Parent or not monsterRoot or not monsterRoot.Parent then
		return
	end

	local parts = collectBreakableParts(rootModel, opts.excludeNames or {})
	if #parts == 0 then
		return
	end

	local cache = rememberDoorTemplate(rootModel)
	local originalCFrames = {}
	for _, part in ipairs(parts) do
		originalCFrames[part] = part.CFrame
	end

	local monsterPos = monsterRoot.Position
	local modelPivot = rootModel:GetPivot()
	local modelCenter = modelPivot.Position
	local pullDir = safeUnit(monsterPos - modelCenter)
	if pullDir == Vector3.zero then
		pullDir = -monsterRoot.CFrame.LookVector
	end

	local holdTime = opts.holdTime or DOOR_HOLD_TIME
	local pullTime = opts.pullTime or DOOR_PULL_TIME
	local yankTime = opts.yankTime or DOOR_YANK_TIME
	local canCollideAfter = opts.canCollideAfter ~= false
	local blowVelocity = opts.blowVelocity or DOOR_FLING_VELOCITY

	local doorCore = findCorePart(rootModel)
	if doorCore then
		local holdPair = spawnPullPairTendrils(
			doorCore,
			1,
			1,
			Vector3.zero,
			{
				thicknessScale = 1.12,
				lengthScale = 1.08,
				markerSizeScale = 0.16,
				sweepScale = 0,
				swirlScale = 0,
				freeRoamScale = 0,
				pairSpreadX = 1.2,
				pairSpreadY = 0.18,
				attackEnabled = false,
			}
		)
		playSound(doorCore, IMPACT_SOUND_ID, 0.8, false)
		task.wait(holdTime)

		local function perPartDentStep(tickRatio)
			for _, part in ipairs(parts) do
				if part and part.Parent then
					local baseCF = originalCFrames[part] or part.CFrame
					local fromMonster = safeUnit(part.Position - monsterPos)
					if fromMonster == Vector3.zero then
						fromMonster = pullDir
					end

					local inward = safeUnit((fromMonster * 0.7) + (pullDir * 0.3))
					local dentOffset = inward * (0.18 * tickRatio)

					local rot = math.rad(DENT_ANGLE_DEGREES) * tickRatio
					local rx = math.random(-1, 1) * rot
					local ry = math.random(-1, 1) * rot
					local rz = math.random(-1, 1) * rot

					part.CFrame = baseCF * CFrame.new(dentOffset) * CFrame.Angles(rx, ry, rz)
				end
			end
		end

		for tick = 1, DENT_TICKS do
			perPartDentStep(tick / DENT_TICKS)
			task.wait(pullTime / DENT_TICKS)
		end

		for _, part in ipairs(parts) do
			if part and part.Parent then
				part.CanCollide = canCollideAfter
				part.CanTouch = true
				part.CanQuery = true
			end
		end

		destroyConnectionsForParts(rootModel, parts)

		for _, part in ipairs(parts) do
			if part and part.Parent then
				part.Anchored = false
				part.AssemblyLinearVelocity = (pullDir * blowVelocity)
					+ Vector3.new(math.random(-20, 20), math.random(-5, 20), math.random(-20, 20))
				part.AssemblyAngularVelocity = Vector3.new(
					math.random(-8, 8),
					math.random(-8, 8),
					math.random(-8, 8)
				)
			end
		end

		task.wait(yankTime)
		beginTendrilRetreat(holdPair, doorCore, monsterRoot, 0.7)
	end

	task.delay(8, function()
		if rootModel and rootModel.Parent then
			rootModel:Destroy()
		end
	end)

	if cache then
		task.delay(DUBBLE_DOOR_REGEN_TIME, function()
			restoreDoorTemplate(cache)
			brokenDoorGuard[rootModel] = nil
		end)
	else
		task.delay(DUBBLE_DOOR_REGEN_TIME, function()
			brokenDoorGuard[rootModel] = nil
		end)
	end
end

