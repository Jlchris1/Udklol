local function raycastVisionToTargetRoot(targetRoot)
	if not targetRoot or not targetRoot.Parent then
		return false, nil
	end

	local origin = rigRoot.Position + Vector3.new(0, 2.5, 0)
	local destination = targetRoot.Position + Vector3.new(0, 2, 0)
	local direction = destination - origin

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = { rig, holder }
	params.IgnoreWater = true

	local result = Workspace:Raycast(origin, direction, params)
	if not result then
		return true, nil
	end

	local hit = result.Instance
	if hit and hit:IsDescendantOf(targetRoot.Parent) then
		return true, nil
	end

	return false, hit
end

local function getAllTargetCandidates()
	local candidates = {}

	for _, inst in ipairs(workspace:GetDescendants()) do
		if inst:IsA("Model") and isValidTargetModel(inst) then
			local root = getModelRoot(inst)
			if root and root:IsA("BasePart") then
				table.insert(candidates, inst)
			end
		end
	end

	return candidates
end

local function estimateTargetVelocity(model, history)
	if not history or #history < 2 then
		local root = getModelRoot(model)
		return root and root.AssemblyLinearVelocity or Vector3.zero
	end

	local a = history[#history - 1]
	local b = history[#history]
	local dt = math.max(b.time - a.time, 0.05)
	return (b.pos - a.pos) / dt
end

local function predictTargetPosition(model, root, history)
	local vel = estimateTargetVelocity(model, history)
	local distance = (root.Position - rigRoot.Position).Magnitude
	local leadTime = math.clamp(distance / math.max(vel.Magnitude, 1), 0.2, 1.25)
	leadTime = math.max(leadTime, math.clamp(distance / 42, 0.2, 1.25))
	return root.Position + vel * leadTime
end

local function findNearestVisibleVictim()
	local bestModel = nil
	local bestDist = SEARCH_RADIUS

	for _, model in ipairs(getAllTargetCandidates()) do
		local root = getModelRoot(model)
		if root and root:IsA("BasePart") then
			local d = (root.Position - rigRoot.Position).Magnitude
			if d < bestDist then
				local visible, blocker = raycastVisionToTargetRoot(root)
				if visible then
					bestDist = d
					bestModel = model
				elseif blocker then
					local blockerModel = blocker:FindFirstAncestorWhichIsA("Model")
					if blockerModel and (blockerModel.Name == "DubbleHallwayDoor" or blockerModel.Name == "DubbleDoors") then
						breakHallwayDoorModel(blockerModel)
					end
				end
			end
		end
	end

	return bestModel, bestDist
end

local function updateRoomEntryStateForTarget(targetModel, targetRoot)
	if not targetModel or not targetRoot or not targetRoot.Parent then
		return
	end

	local roomModel = getTunnelRoomContainingPosition(targetRoot.Position)
	local prevState = sightState[targetModel]
	if not prevState then
		prevState = {
			visible = false,
			lastVisibleTime = 0,
			lastVisibleRoom = nil,
			lastVisiblePos = nil,
		}
		sightState[targetModel] = prevState
	end

	if roomModel then
		local roomStates = roomPresenceState[roomModel]
		if not roomStates then
			roomStates = {}
			roomPresenceState[roomModel] = roomStates
		end

		local wasInside = roomStates[targetModel] == true
		roomStates[targetModel] = true

		if not wasInside then
			markTunnelRoomEntry(roomModel, targetModel)
		end

		prevState.lastVisibleRoom = roomModel
	else
		for rm, roomStates in pairs(roomPresenceState) do
			if roomStates[targetModel] ~= nil then
				roomStates[targetModel] = nil
			end
		end
	end
end

local function inspectRoomForTarget(roomModel, duration)
	local start = os.clock()

	local ok, boxCF, boxSize = pcall(function()
		return roomModel:GetBoundingBox()
	end)

	if not ok then
		return nil
	end

	while os.clock() - start < duration do
		if not rig.Parent or not rigRoot.Parent then
			return nil
		end

		for _, inst in ipairs(workspace:GetDescendants()) do
			if inst:IsA("Model") and inst ~= rig and isValidTargetModel(inst) then
				local root = getModelRoot(inst)
				if root and root:IsA("BasePart") and isPointInsideBox(boxCF, boxSize, root.Position) then
					return inst
				end
			end
		end

		task.wait(0.2)
	end

	return nil
end

