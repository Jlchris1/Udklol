local function runGrabSequence(targetModel)
	local targetHumanoid = targetModel:FindFirstChildOfClass("Humanoid")
	local targetRoot = getModelRoot(targetModel)

	if not targetHumanoid or not targetRoot or not targetRoot:IsA("BasePart") then
		return
	end

	if isProtectedCreature(targetModel) then
		return
	end

	local monsterRoot = getNearestMouthMonsterRoot()
	if not monsterRoot or not monsterRoot.Parent then
		return
	end

	local limbSpecs = getLimbSpecs(targetModel)
	local headPart = getMonsterHeadPart()

	forcePlatformStand(targetModel)
	targetHumanoid.WalkSpeed = 0
	targetHumanoid.JumpPower = 0
	targetHumanoid.BreakJointsOnDeath = false

	targetRoot.Anchored = true
	targetRoot.CanCollide = false
	targetRoot.CanQuery = false

	npcHumanoid.WalkSpeed = 0
	npcHumanoid:Move(Vector3.zero, false)

	currentAttackTargetPart = targetRoot
	currentAttackIntensity = 1

	local monsterLoopSound = playSound(monsterRoot, MONSTER_SOUND_ID, 1, true)
	playSound(targetRoot, CAUGHT_SOUND_ID, 1, false)

	local holdPair = spawnPullPairTendrils(
		targetRoot,
		1,
		1,
		Vector3.new(0, torsoPart.Size.Y * 0.55 + HOLD_HEIGHT, -(torsoPart.Size.Z * 0.45 + 1.4)),
		{
			thicknessScale = 1.2,
			lengthScale = 1.18,
			markerSizeScale = 0.2,
			sweepScale = 0.0,
			swirlScale = 0.0,
			freeRoamScale = 0,
			pairSpreadX = 1.65,
			pairSpreadY = 0.25,
			attackEnabled = true,
		}
	)

	local keepHolding = true
	task.spawn(function()
		while keepHolding and targetRoot.Parent and monsterRoot.Parent and targetHumanoid.Health > 0 do
			forcePlatformStand(targetModel)
			updateHeldTargetPosition(targetRoot, monsterRoot)
			task.wait()
		end
	end)

	task.wait(0.25)

	local limbsTorn = 0

	for _, limb in ipairs(limbSpecs) do
		if not targetModel.Parent or targetHumanoid.Health <= 0 then
			break
		end

		local grabPart = limb.grabPart
		if grabPart and grabPart.Parent then
			local sideSign = ((grabPart.Position - monsterRoot.Position):Dot(monsterRoot.CFrame.RightVector) >= 0) and 1 or -1
			local liftSign = ((grabPart.Position.Y - monsterRoot.Position.Y) >= 0) and 1 or -1

			local limbPair = spawnPullPairTendrils(
				grabPart,
				sideSign,
				liftSign,
				Vector3.new(sideSign * 2.6, torsoPart.Size.Y * 0.35, -(torsoPart.Size.Z * 0.5 + 1.2)),
				{
					thicknessScale = 1.08,
					lengthScale = 1.12,
					markerSizeScale = 0.18,
					sweepScale = 0.0,
					swirlScale = 0.0,
					freeRoamScale = 0,
					pairSpreadX = 1.15,
					pairSpreadY = 0.18,
					attackEnabled = true,
				}
			)

			local start = os.clock()
			while os.clock() - start < LIMB_TEAR_TIME do
				if not targetModel.Parent or targetHumanoid.Health <= 0 then
					break
				end
				forcePlatformStand(targetModel)
				updateHeldTargetPosition(targetRoot, monsterRoot)
				task.wait(0.08)
			end

			if grabPart and grabPart.Parent then
				severLimbGroup(targetModel, limb.parts, monsterRoot, headPart)
				limbsTorn += 1
				playSound(targetRoot, TORN_SOUND_ID, 1, false)
				if targetHumanoid.Health > 0 then
					targetHumanoid:TakeDamage(LIMB_DAMAGE)
				end
			end

			beginTendrilRetreat(limbPair, grabPart, monsterRoot, 0.9)
		end
	end

	keepHolding = false
	for _, t in ipairs(holdPair) do
		destroyTendril(t)
	end

	local function cleanupGrab()
		if monsterLoopSound then
			monsterLoopSound:Stop()
			monsterLoopSound:Destroy()
		end

		currentAttackTargetPart = nil
		currentAttackIntensity = 0
		grabbing = false
		npcHumanoid.WalkSpeed = PATROL_SPEED
		npcHumanoid.AutoRotate = true
	end

	local allLimbsGone = (#limbSpecs > 0 and limbsTorn >= #limbSpecs)

	if targetModel.Parent and targetRoot and targetRoot.Parent then
		if allLimbsGone then
			setModelAnchored(targetModel, false)
			setModelCollisionGroup(targetModel, NPC_GROUP)
			setModelCanCollide(targetModel, false)
			setModelCanQuery(targetModel, false)

			forcePlatformStand(targetModel)
			targetHumanoid.WalkSpeed = 0
			targetHumanoid.JumpPower = 0

			currentAttackTargetPart = targetRoot
			currentAttackIntensity = 1

			local torsoPair = spawnPullPairTendrils(
				targetRoot,
				1,
				1,
				Vector3.new(0, torsoPart.Size.Y * 0.35, -(torsoPart.Size.Z * 0.5 + 1.2)),
				{
					thicknessScale = 1.18,
					lengthScale = 1.12,
					markerSizeScale = 0.2,
					sweepScale = 0.0,
					swirlScale = 0.0,
					freeRoamScale = 0,
					pairSpreadX = 1.55,
					pairSpreadY = 0.22,
					attackEnabled = true,
				}
			)

			slowlyBringVictimToMouth(targetModel, targetRoot, headPart)

			forcePlatformStand(targetModel)
			teleportModelToPosition(targetModel, EAT_TELEPORT_POS)
			ragdollModel(targetModel)

			for _, t in ipairs(torsoPair) do
				destroyTendril(t)
			end

			currentAttackTargetPart = nil
			currentAttackIntensity = 0
		else
			forcePlatformStand(targetModel)
			targetRoot.Anchored = false
			targetRoot.CanCollide = true
			targetRoot.CanQuery = true
			targetRoot.AssemblyLinearVelocity = Vector3.new(0, -90, 0) + monsterRoot.CFrame.LookVector * 20
			task.wait(0.25)
			playSound(targetRoot, IMPACT_SOUND_ID, 1, false)

			forcePlatformStand(targetModel)
			teleportModelToPosition(targetModel, EAT_TELEPORT_POS)
			ragdollModel(targetModel)

			targetRoot.AssemblyLinearVelocity = Vector3.zero
			targetRoot.AssemblyAngularVelocity = Vector3.zero
		end
	end

	cleanupGrab()
end

