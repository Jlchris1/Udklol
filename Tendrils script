local function collectTendrilPointParts(rigModel, holderFolder)
	local points = {}

	for _, inst in ipairs(rigModel:GetDescendants()) do
		if inst:IsA("BasePart") and not inst:IsDescendantOf(holderFolder) then
			local index = getPointIndex(inst.Name)
			if index ~= nil then
				table.insert(points, {
					part = inst,
					index = index,
					config = getPointSettingsFromOverride(inst.Name, getPointSettingsFromPart(inst)),
				})
			end
		end
	end

	table.sort(points, function(a, b)
		if a.index == b.index then
			return a.part.Name < b.part.Name
		end
		return a.index < b.index
	end)

	return points
end

local function buildDefaultRootOffsets(count, torsoSize)
	local offsets = {}
	local backDistance = math.max(torsoSize.Z * 0.5 + 0.45, 0.85)
	local ringRadius = math.max(torsoSize.X * 0.38, 1.65)

	if count == 1 then
		offsets[1] = Vector3.new(0, 0, backDistance)
		return offsets
	end

	if count == 2 then
		local x = ringRadius * 0.65
		offsets[1] = Vector3.new(-x, 0, backDistance)
		offsets[2] = Vector3.new(x, 0, backDistance)
		return offsets
	end

	local angleOffset = -math.pi / 2
	for i = 1, count do
		local angle = angleOffset + ((i - 1) / count) * math.pi * 2
		local x = math.cos(angle) * ringRadius
		local y = math.sin(angle) * (ringRadius * 0.72)
		offsets[i] = Vector3.new(x, y, backDistance)
	end

	return offsets
end

