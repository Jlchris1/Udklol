local function isModelTouchingAnyTendril(model, rangePadding)
	if not model or not model.Parent then
		return false
	end

	local ok, boxCF, boxSize = pcall(function()
		return model:GetBoundingBox()
	end)
	if not ok then
		return false
	end

	local parts = {}
	for _, t in ipairs(tendrils) do
		if t and not t._dead then
			for _, p in ipairs(t.parts) do
				if p and p.Parent then
					table.insert(parts, p)
				end
			end
		end
	end

	local threshold = rangePadding or 0
	for _, p in ipairs(parts) do
		local d = (p.Position - boxCF.Position).Magnitude
		local half = math.max(boxSize.X, boxSize.Y, boxSize.Z) * 0.5
		local pHalf = math.max(p.Size.X, p.Size.Y, p.Size.Z) * 0.5
		if d <= half + pHalf + threshold then
			return true
		end
	end

	return false
end

