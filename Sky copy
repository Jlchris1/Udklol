local function safeGet(inst, prop)
	local ok, val = pcall(function()
		return inst[prop]
	end)
	if ok then
		return val
	end
	return nil
end

local function collectProperties(inst)
	local props = {}
	local list = propertyLists[inst.ClassName] or {}

	for _, prop in ipairs(list) do
		local val = safeGet(inst, prop)
		if val ~= nil then
			props[prop] = val
		end
	end

	local attrs = {}
	local ok, got = pcall(function()
		return inst:GetAttributes()
	end)
	if ok and got and next(got) then
		props._Attributes = got
	end

	return props
end

