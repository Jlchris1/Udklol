function showProperties(inst)
	clearPanel(rightPanel)

	local header = Instance.new("TextLabel")
	header.Size = UDim2.new(1, 0, 0, 30)
	header.BackgroundTransparency = 1
	header.Font = Enum.Font.SourceSansBold
	header.TextSize = 16
	header.TextColor3 = rgb3(240, 240, 240)
	header.Text = string.format("%s — %s", inst.Name or "<unnamed>", inst.ClassName or "Instance")
	header.TextXAlignment = Enum.TextXAlignment.Left
	header.Parent = rightPanel

	local objectCodeBtn = Instance.new("TextButton")
	objectCodeBtn.Size = UDim2.new(0, 150, 0, 30)
	objectCodeBtn.Text = "Copy object code"
	objectCodeBtn.Font = Enum.Font.SourceSansBold
	objectCodeBtn.TextSize = 14
	objectCodeBtn.BackgroundTransparency = 0.12
	objectCodeBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
	objectCodeBtn.TextColor3 = rgb3(240, 240, 240)
	objectCodeBtn.Parent = rightPanel
	makeCorner(objectCodeBtn, UDim.new(0, 6))

	objectCodeBtn.MouseButton1Click:Connect(function()
		local code = createSingleObjectCode(inst)
		local ok = copyText(code, "Copy object code")
		if ok then
			toast("Copied object code")
		else
			toast("Clipboard unavailable")
		end
	end)

	local props = collectProperties(inst)

	for _, key in ipairs(sortedKeys(props)) do
		if key == "_Attributes" then
			local attrHeader = Instance.new("TextLabel")
			attrHeader.Size = UDim2.new(1, 0, 0, 20)
			attrHeader.BackgroundTransparency = 1
			attrHeader.Font = Enum.Font.SourceSansSemibold
			attrHeader.TextSize = 13
			attrHeader.TextColor3 = rgb3(220, 220, 220)
			attrHeader.TextXAlignment = Enum.TextXAlignment.Left
			attrHeader.Text = "Attributes"
			attrHeader.Parent = rightPanel

			for _, ak in ipairs(sortedKeys(props._Attributes)) do
				local av = props._Attributes[ak]
				makeRow(rightPanel, tostring(ak), makeValueDisplay(av), serializeValue(av))
			end
		else
			local v = props[key]
			makeRow(rightPanel, tostring(key), makeValueDisplay(v), serializeValue(v))
		end
	end
end

