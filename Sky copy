local function pathExprFromWorkspace(inst)
	if not inst or not inst:IsDescendantOf(Workspace) then
		return nil
	end

	local pieces = {}
	local current = inst
	while current and current ~= Workspace do
		table.insert(pieces, 1, current.Name)
		current = current.Parent
	end

	local expr = "workspace"
	for _, name in ipairs(pieces) do
		expr ..= string.format(":WaitForChild(%s)", escapeLuaString(name))
	end
	return expr
end

local function append(lines, indentLevel, text)
	table.insert(lines, string.rep("    ", indentLevel) .. text)
end

local function serializePropertiesToCode(lines, indentLevel, targetExpr, inst)
	local props = collectProperties(inst)
	for _, key in ipairs(sortedKeys(props)) do
		if key ~= "_Attributes" then
			local expr = serializeValue(props[key])
			if expr and expr ~= "nil" then
				append(lines, indentLevel, string.format("%s.%s = %s", targetExpr, key, expr))
			end
		end
	end

	if props._Attributes then
		for _, key in ipairs(sortedKeys(props._Attributes)) do
			local expr = serializeValue(props._Attributes[key])
			if expr and expr ~= "nil" then
				append(lines, indentLevel, string.format("%s:SetAttribute(%s, %s)", targetExpr, escapeLuaString(key), expr))
			end
		end
	end
end

local function createSingleObjectCode(inst)
	if inst == Lighting then
		return generateLightingCode(false)
	end

	if inst:IsA("ParticleEmitter") then
		return generateParticleCodeForEmitter(inst)
	end

	local lines = {}
	append(lines, 0, "-- Generated object code")
	append(lines, 0, "local Lighting = game:GetService(\"Lighting\")")
	append(lines, 0, "")
	append(lines, 0, "-- Recreate this effect")
	append(lines, 0, string.format("local obj = Instance.new(%s)", escapeLuaString(inst.ClassName)))
	append(lines, 0, string.format("obj.Name = %s", escapeLuaString(inst.Name)))

	serializePropertiesToCode(lines, 0, "obj", inst)

	local parentExpr = "Lighting"
	if inst.Parent and inst.Parent ~= Lighting then
		local pe = pathExprFromWorkspace(inst.Parent)
		if pe then
			parentExpr = pe
		end
	end
	append(lines, 0, string.format("obj.Parent = %s", parentExpr))
	return table.concat(lines, "\n")
end

function generateLightingCode(includeParticles)
	local lines = {}

	append(lines, 0, "-- Generated lighting / sky / atmosphere code")
	append(lines, 0, "local Lighting = game:GetService(\"Lighting\")")
	append(lines, 0, "local Workspace = game:GetService(\"Workspace\")")
	append(lines, 0, "")
	append(lines, 0, "for _, child in ipairs(Lighting:GetChildren()) do")
	append(lines, 1, "if child:IsA(\"Sky\") or child:IsA(\"Atmosphere\") or child:IsA(\"ColorCorrectionEffect\") or child:IsA(\"BloomEffect\") or child:IsA(\"SunRaysEffect\") or child:IsA(\"BlurEffect\") or child:IsA(\"DepthOfFieldEffect\") then")
	append(lines, 2, "child:Destroy()")
	append(lines, 1, "end")
	append(lines, 0, "end")
	append(lines, 0, "")

	serializePropertiesToCode(lines, 0, "Lighting", Lighting)
	append(lines, 0, "")

	local handled = {
		Sky = true,
		Atmosphere = true,
		ColorCorrectionEffect = true,
		BloomEffect = true,
		SunRaysEffect = true,
		BlurEffect = true,
		DepthOfFieldEffect = true,
	}

	local counters = {}

	for _, child in ipairs(Lighting:GetChildren()) do
		if handled[child.ClassName] and child ~= Lighting then
			counters[child.ClassName] = (counters[child.ClassName] or 0) + 1
			local varName = string.lower(child.ClassName) .. tostring(counters[child.ClassName])

			append(lines, 0, string.format("local %s = Instance.new(%s)", varName, escapeLuaString(child.ClassName)))
			append(lines, 0, string.format("%s.Name = %s", varName, escapeLuaString(child.Name)))
			serializePropertiesToCode(lines, 0, varName, child)
			append(lines, 0, string.format("%s.Parent = Lighting", varName))
			append(lines, 0, "")
		end
	end

	if includeParticles then
		append(lines, 0, "-- Particle emitters are excluded from this copy.")
	end

	return table.concat(lines, "\n")
end

function generateParticleCodeForEmitter(emitter)
	local parentExpr = pathExprFromWorkspace(emitter.Parent)
	if not parentExpr then
		parentExpr = "workspace"
	end

	local lines = {}
	append(lines, 0, "-- Generated particle emitter code")
	append(lines, 0, "local Workspace = game:GetService(\"Workspace\")")
	append(lines, 0, "")
	append(lines, 0, string.format("local emitter = Instance.new(%s)", escapeLuaString("ParticleEmitter")))
	append(lines, 0, string.format("emitter.Name = %s", escapeLuaString(emitter.Name)))
	serializePropertiesToCode(lines, 0, "emitter", emitter)
	append(lines, 0, string.format("emitter.Parent = %s", parentExpr))
	return table.concat(lines, "\n")
end

function generateParticleCode()
	local lines = {}
	append(lines, 0, "-- Generated particle emitter code")
	append(lines, 0, "local Workspace = game:GetService(\"Workspace\")")
	append(lines, 0, "")

	local emitters = {}
	for _, inst in ipairs(Workspace:GetDescendants()) do
		if inst:IsA("ParticleEmitter") then
			table.insert(emitters, inst)
		end
	end

	if #emitters == 0 then
		append(lines, 0, "-- No particle emitters found.")
		return table.concat(lines, "\n")
	end

	for i, emitter in ipairs(emitters) do
		local parentExpr = pathExprFromWorkspace(emitter.Parent)
		if parentExpr then
			append(lines, 0, string.format("do -- %s", escapeLuaString(emitter:GetFullName())))
			append(lines, 1, string.format("local emitter = Instance.new(%s)", escapeLuaString("ParticleEmitter")))
			append(lines, 1, string.format("emitter.Name = %s", escapeLuaString(emitter.Name)))
			serializePropertiesToCode(lines, 1, "emitter", emitter)
			append(lines, 1, string.format("emitter.Parent = %s", parentExpr))
			append(lines, 0, "end")
			if i < #emitters then
				append(lines, 0, "")
			end
		end
	end

	return table.concat(lines, "\n")
end

local function scanParticleEmitters()
	local out = {}
	for _, inst in ipairs(Workspace:GetDescendants()) do
		if inst:IsA("ParticleEmitter") then
			table.insert(out, inst)
		end
	end
	return out
end

local function scanLightingEffects()
	local out = { Lighting }
	for _, inst in ipairs(Lighting:GetChildren()) do
		if inst:IsA("Atmosphere")
			or inst:IsA("Sky")
			or inst:IsA("ColorCorrectionEffect")
			or inst:IsA("BloomEffect")
			or inst:IsA("SunRaysEffect")
			or inst:IsA("BlurEffect")
			or inst:IsA("DepthOfFieldEffect")
		then
			table.insert(out, inst)
		end
	end
	return out
end

