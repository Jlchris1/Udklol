local function escapeLuaString(s)
	return string.format("%q", s)
end

local function serializeValue(v)
	local t = typeof(v)

	if t == "nil" then
		return "nil"
	elseif t == "string" then
		return escapeLuaString(v)
	elseif t == "number" or t == "boolean" then
		return tostring(v)
	elseif t == "EnumItem" then
		return tostring(v)
	elseif t == "Color3" then
		return string.format("Color3.new(%.6f, %.6f, %.6f)", v.R, v.G, v.B)
	elseif t == "Vector2" then
		return string.format("Vector2.new(%.6f, %.6f)", v.X, v.Y)
	elseif t == "Vector3" then
		return string.format("Vector3.new(%.6f, %.6f, %.6f)", v.X, v.Y, v.Z)
	elseif t == "UDim" then
		return string.format("UDim.new(%.6f, %d)", v.Scale, v.Offset)
	elseif t == "UDim2" then
		return string.format(
			"UDim2.new(%.6f, %d, %.6f, %d)",
			v.X.Scale, v.X.Offset,
			v.Y.Scale, v.Y.Offset
		)
	elseif t == "BrickColor" then
		return string.format("BrickColor.new(%s)", escapeLuaString(v.Name))
	elseif t == "NumberRange" then
		return string.format("NumberRange.new(%.6f, %.6f)", v.Min, v.Max)
	elseif t == "NumberSequence" then
		local points = {}
		local ok, keypoints = pcall(function()
			return v.Keypoints
		end)
		if ok and keypoints then
			for _, kp in ipairs(keypoints) do
				table.insert(points, string.format(
					"NumberSequenceKeypoint.new(%.6f, %.6f, %.6f)",
					kp.Time, kp.Value, kp.Envelope or 0
				))
			end
		end
		return "NumberSequence.new({" .. table.concat(points, ", ") .. "})"
	elseif t == "ColorSequence" then
		local points = {}
		local ok, keypoints = pcall(function()
			return v.Keypoints
		end)
		if ok and keypoints then
			for _, kp in ipairs(keypoints) do
				table.insert(points, string.format(
					"ColorSequenceKeypoint.new(%.6f, %s)",
					kp.Time,
					serializeValue(kp.Value)
				))
			end
		end
		return "ColorSequence.new({" .. table.concat(points, ", ") .. "})"
	elseif t == "CFrame" then
		local comps = { v:GetComponents() }
		return string.format(
			"CFrame.new(%.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f)",
			comps[1], comps[2], comps[3],
			comps[4], comps[5], comps[6],
			comps[7], comps[8], comps[9],
			comps[10], comps[11], comps[12]
		)
	elseif t == "Rect" then
		return string.format("Rect.new(%s, %s)", serializeValue(v.Min), serializeValue(v.Max))
	elseif t == "Instance" then
		return string.format("<Instance %s (%s)>", v.Name, v.ClassName)
	elseif t == "table" then
		local parts = {}
		for k, val in pairs(v) do
			table.insert(parts, string.format("[%s] = %s", serializeValue(k), serializeValue(val)))
		end
		return "{ " .. table.concat(parts, ", ") .. " }"
	end

	return tostring(v)
end

local function sortedKeys(tbl)
	local keys = {}
	for k in pairs(tbl) do
		table.insert(keys, k)
	end
	table.sort(keys, function(a, b)
		return tostring(a) < tostring(b)
	end)
	return keys
end

