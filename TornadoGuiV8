-- ========== LIVE REBUILD ==========
local function liveRebuild()
    if not enabled then return end
    
    if tornadoType == "Rope" then
        for id, _ in pairs(satelliteVortices) do despawnSatellite(id) end
        for part in pairs(mainFunnelSet) do
            if part and part.Parent then
                whitelistedParts[part] = true
                pickedUpByFunnel[part] = true
                assignedToSatellite[part] = nil
                mainFunnelSet[part] = nil
            end
        end
        mainFunnelParts = {}
        mainFunnelSet = {}
        if #ropeParts == 0 then
            setupRopeTornado()
        end
        ropeActualCenters = {}
    else
        for part in pairs(ropeParts) do
            if part and part.Parent then
                part.AssemblyLinearVelocity = Vector3.zero
                part.CanCollide = true
                whitelistedParts[part] = true
                pickedUpByFunnel[part] = true
            end
            ropeParts[part] = nil
        end
        ropeLines = {}
        ropeSegments = {}
        formSatellitesInstant()
    end
    
    tornadoPathTargets = {}
    tornadoStalkTargets = {}
    
    updatePositions()
end

-- ========== HELPER FUNCTIONS ==========
local function isPlayerPart(part)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character and part:IsDescendantOf(plr.Character) then return true end
    end
    return false
end

local function clamp(val, a, b)
    if val < a then return a end
    if val > b then return b end
    return val
end

local function processPartForFunnel(obj)
    if obj:IsA("BasePart") and not obj.Anchored and not isPlayerPart(obj) and obj.Name ~= baseplateName then
        if not whitelistedParts[obj] and not assignedToSatellite[obj] and not noodlePartSet[obj] and not mainFunnelSet[obj] and not ropeParts[obj] then
            pickedUpByFunnel[obj] = true; whitelistedParts[obj] = true
            
            if partsFrozen and obj and obj.Parent then
                frozenParts[obj] = obj.Anchored
                obj.Anchored = true
            end
        end
    end
end

local function snapPartDown(part, targetY)
    if not part or not part.Parent then return end
    if debrisAttachedToPlayer[part] then return end
    local vel = part.AssemblyLinearVelocity
    part.AssemblyLinearVelocity = Vector3.new(vel.X, -math.abs(vel.Y) - math.abs(tornadoUpwardSpeed * 1.5), vel.Z)
end

local function reserveMainFunnelParts()
    mainFunnelParts = {}; mainFunnelSet = {}
    local candidates = {}
    for p in pairs(whitelistedParts) do
        if p and p.Parent and not p.Anchored and not assignedToSatellite[p] and not noodlePartSet[p] and not ropeParts[p] then
            local d = 0
            local center = tornadoPositions[1] or (localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") and localPlayer.Character.HumanoidRootPart.Position) or Vector3.new(0,10,0)
            if p.Position then d = (p.Position - center).Magnitude end
            table.insert(candidates, {part = p, dist = d})
        end
    end
    if #candidates == 0 then return end
    table.sort(candidates, function(a,b) return a.dist < b.dist end)
    local available = #candidates
    local desiredByShare = math.floor(available * mainFunnelShare + 0.5)
    local take = math.min(available, math.max(funnelReserveCount, desiredByShare))
    for i = 1, take do
        local p = candidates[i].part
        if p then
            mainFunnelParts[#mainFunnelParts + 1] = p; mainFunnelSet[p] = true
            whitelistedParts[p] = nil; pickedUpByFunnel[p] = nil; assignedToSatellite[p] = nil
        end
    end
end

-- ========== APPL FUNNEL FORCE ==========
local function applyFunnelForceToPart(part, centerPos, delta, isMain)
    if not part or not part.Parent then return end
    local offset = part.Position - centerPos
    local horizontalOffset = Vector3.new(offset.X, 0, offset.Z)
    local distance = math.max(0.1, horizontalOffset.Magnitude)
    local dirToCenter = horizontalOffset.Unit
    local spinDir = Vector3.new(-dirToCenter.Z, 0, dirToCenter.X)

    local maxRadius = tornadoWindfield
    local clampedDist = math.min(distance, maxRadius)
    
    local relativeHeight = math.clamp((part.Position.Y - centerPos.Y) / math.max(1, funnelHeight), 0, 1)
    
    local bulgeFactor = 1.0
    if relativeHeight > 0.2 and relativeHeight < 0.8 then
        local bulgePeak = 0.5
        local bulgeStrength = 1.8
        local bulgeCurve = math.max(0, 1 - math.abs(relativeHeight - bulgePeak) / 0.3)
        bulgeFactor = 1.0 + (bulgeStrength - 1.0) * bulgeCurve
    end
    
    local outwardBias = 0
    if relativeHeight > 0.25 and relativeHeight < 0.75 then
        local outwardPeak = 0.5
        local outwardStrength = 30
        local outwardCurve = math.max(0, 1 - math.abs(relativeHeight - outwardPeak) / 0.25)
        outwardBias = outwardStrength * outwardCurve
    end
    
    local movementOffset = Vector3.new(0, 0, 0)
    local tornadoIdx = nil
    for idx, pos in ipairs(tornadoPositions) do
        if (pos - centerPos).Magnitude < 1 then
            tornadoIdx = idx
            break
        end
    end
    if tornadoIdx and prevTornadoPositions[tornadoIdx] then
        local moveDelta = centerPos - prevTornadoPositions[tornadoIdx]
        if moveDelta.Magnitude > 0.5 then
            movementOffset = moveDelta * 0.3
        end
    end
    
    local spinVelocity = tornadoSpinSpeed * (1 + (clampedDist / math.max(1, maxRadius)) * 0.1)
    local inwardPull = -dirToCenter * tornadoInwardPullSpeed * (1 / math.max(1, bulgeFactor))
    local rotational = spinDir * spinVelocity
    local upward = Vector3.new(0, tornadoUpwardSpeed, 0)
    
    local outwardPush = dirToCenter * outwardBias
    
    local time = tick()
    local bobFreq = 1.5 + (clampedDist / math.max(1, maxRadius)) * 0.5
    local bobAmp = 8 + math.sin(time * 0.3 + distance * 0.01) * 3
    local anglePhase = math.atan2(offset.Z, offset.X) or 0
    local bobOffset = math.sin(time * bobFreq + anglePhase) * bobAmp
    upward = upward + Vector3.new(0, bobOffset * delta * 3, 0)
    
    local targetVel = rotational + inwardPull + outwardPush + upward + movementOffset
    local currentVel = part.AssemblyLinearVelocity
    
    local smoothFactor = math.min(1, delta * 4)
    local finalVel = currentVel:Lerp(targetVel, smoothFactor)
    
    if finalVel.Magnitude > 800 then
        finalVel = finalVel.Unit * 800
    end
    
    if not part.Anchored then
        part.AssemblyLinearVelocity = finalVel
        part.CanCollide = false
    end
    return finalVel
end

local function updateMainFunnel(delta)
    if #tornadoPositions == 0 then return end
    local centerPos = tornadoPositions[1]
    for i, p in ipairs(mainFunnelParts) do
        if not p or not p.Parent then mainFunnelParts[i] = nil
        else
            applyFunnelForceToPart(p, centerPos, delta, true)
            if p.Position.Y >= (centerPos.Y + funnelHeight) then snapPartDown(p, centerPos.Y) end
        end
    end
    local newMain = {}
    for _, v in ipairs(mainFunnelParts) do if v then table.insert(newMain, v) end end
    mainFunnelParts = newMain
end

