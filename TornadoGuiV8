-- NIGHTMARE MODE: INDIVIDUAL PARTS FLING WITH AlignPosition/Torque
-- =====================================================

local function pushVelocitySample(pl, vel, now)
    if not pl then return end
    playerVelBuffer[pl] = playerVelBuffer[pl] or {}
    local buf = playerVelBuffer[pl]
    table.insert(buf, 1, {t = now, v = vel})
    while #buf > 6 do table.remove(buf) end
end

local function estimateAccelFromBuffer(pl)
    local buf = playerVelBuffer[pl]
    if not buf or #buf < 2 then return Vector3.new(0,0,0) end
    local total = Vector3.new(0,0,0)
    local count = 0
    for i = 1, #buf-1 do
        local cur = buf[i].v
        local nxt = buf[i+1].v
        local dt = buf[i].t - buf[i+1].t
        if dt > 0 then
            total = total + (cur - nxt) / dt
            count = count + 1
        end
    end
    if count == 0 then return Vector3.new(0,0,0) end
    return total / count
end

local function getClientPing()
    local ok, ping = pcall(function()
        if localPlayer and localPlayer.GetNetworkPing then
            return localPlayer:GetNetworkPing()
        end
        return nil
    end)
    if ok and type(ping) == "number" and ping > 0 then
        return ping
    end
    return 0.075
end

local function predictTargetPosition(pl, pos, vel, now)
    pushVelocitySample(pl, vel, now)
    local accel_est = estimateAccelFromBuffer(pl)
    local ping = getClientPing()
    local baseLead = 0.05
    local effectiveLat = clamp(ping + baseLead, 0.03, 0.45)
    local speed = vel.Magnitude
    local speedFactor = clamp(0.12 + (speed * 0.03), 0.12, 1.4)
    local leadTime = effectiveLat * speedFactor
    leadTime = clamp(leadTime, 0.03, 0.6)
    local predicted = pos + vel * leadTime + 0.5 * accel_est * (leadTime * leadTime)
    return predicted, leadTime, accel_est, ping
end

local function getAllNonLocalPlayers()
    local res = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p and p ~= localPlayer and p.Parent then
            table.insert(res, p)
        end
    end
    return res
end

local function getRandomTargetPlayer()
    local players = getAllNonLocalPlayers()
    if #players == 0 then return nil end
    return players[math.random(1, #players)]
end

local function stripBodyForces(part)
    for _, x in next, part:GetChildren() do
        if x:IsA("BodyAngularVelocity") or x:IsA("BodyForce") or x:IsA("BodyGyro")
        or x:IsA("BodyPosition") or x:IsA("BodyThrust") or x:IsA("BodyVelocity")
        or x:IsA("RocketPropulsion") then
            x:Destroy()
        end
    end
    if part:FindFirstChild("Attachment") then part:FindFirstChild("Attachment"):Destroy() end
    if part:FindFirstChild("AlignPosition") then part:FindFirstChild("AlignPosition"):Destroy() end
    if part:FindFirstChild("Torque") then part:FindFirstChild("Torque"):Destroy() end
end

local function createNightmareAttachmentForPart(part, targetPlayer)
    stripBodyForces(part)
    part.CanCollide = false
    
    local partAtt = Instance.new("Attachment", part)
    
    local alignPos = Instance.new("AlignPosition", part)
    alignPos.Attachment0 = partAtt
    
    local targetAtt = Instance.new("Attachment", localPlayer.Character:FindFirstChild("HumanoidRootPart"))
    if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        targetAtt = Instance.new("Attachment", targetPlayer.Character.HumanoidRootPart)
    end
    
    alignPos.Attachment1 = targetAtt
    
    local ok, isMass = pcall(function() return part.Massless end)
    local maxF = PULL_MAX_FORCE
    local resp = PULL_RESPONSIVENESS
    if ok and isMass == true then
        maxF = maxF * MASSLESS_PULL_SCALE
        resp = resp * MASSLESS_RESP_SCALE
    end
    
    alignPos.MaxForce = maxF
    alignPos.MaxVelocity = math.huge
    alignPos.Responsiveness = resp
    
    local torqueVal = FLING_TORQUE
    if ok and isMass == true then
        torqueVal = torqueVal * MASSLESS_TORQUE_SCALE
    end
    local torque = Instance.new("Torque", part)
    torque.Torque = torqueVal
    torque.Attachment0 = partAtt
    
    local data = {
        part = part,
        attachment = partAtt,
        alignPos = alignPos,
        targetAttachment = targetAtt,
        torque = torque,
        targetPlayer = targetPlayer,
        phase = math.random() * math.pi * 2,
        orbitRadius = INDIVIDUAL_ORBIT_RADIUS_BASE + (math.random() * INDIVIDUAL_ORBIT_RADIUS_VARY),
        orbitSpeed = INDIVIDUAL_ORBIT_SPEED + (math.random() * 1.5),
        verticalAmp = INDIVIDUAL_VERTICAL_OSCILLATION * (0.5 + math.random()),
        nextSwitchTime = INDIVIDUAL_SWITCH_INTERVAL_BASE + (math.random() * INDIVIDUAL_SWITCH_INTERVAL_VARY),
        switchingLock = false,
    }
    
    nightmareIndividualPartsData[part] = data
    return data
end

local function reassignNightmarePart(part)
    local data = nightmareIndividualPartsData[part]
    if not data then return end
    
    local newPlayer = getRandomTargetPlayer()
    if not newPlayer then return end
    
    data.targetPlayer = newPlayer
    if data.targetAttachment and data.targetAttachment.Parent then
        pcall(function() data.targetAttachment.Parent:Destroy() end)
    end
    
    local newAtt = Instance.new("Attachment", newPlayer.Character:FindFirstChild("HumanoidRootPart"))
    data.targetAttachment = newAtt
    if data.alignPos then
        pcall(function() data.alignPos.Attachment1 = newAtt end)
    end
    
    data.phase = math.random() * math.pi * 2
    data.orbitRadius = INDIVIDUAL_ORBIT_RADIUS_BASE + (math.random() * INDIVIDUAL_ORBIT_RADIUS_VARY)
    data.orbitSpeed = INDIVIDUAL_ORBIT_SPEED + (math.random() * 1.5)
end

local function startNightmarePartThread(part, data)
    spawn(function()
        local timeAccum = 0
        while nightmareMode and enabled and part and part.Parent and data and data.part == part do
            local dt = RunService.Heartbeat:Wait()
            if not dt then dt = 0.016 end
            timeAccum = timeAccum + dt
            
            local player = data.targetPlayer
            if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = player.Character.HumanoidRootPart
                local pos = hrp.Position
                local vel = hrp.Velocity or Vector3.new(0,0,0)
                local speed = vel.Magnitude
                local dir = (speed > 1) and vel.Unit or hrp.CFrame.LookVector
                
                local predictedPos = predictTargetPosition(player, pos, vel, tick())
                
                -- Orbital motion
                local phase = data.phase + timeAccum * data.orbitSpeed
                local radius = data.orbitRadius * (1 + 0.3 * math.sin(timeAccum * 0.7 + data.phase))
                local orbitX = math.cos(phase) * radius
                local orbitZ = math.sin(phase * 0.8) * radius * 0.7
                local verticalOffset = math.sin(timeAccum * 1.3 + data.phase * 1.7) * data.verticalAmp
                
                -- Chaos based on player speed
                local chaosFactor = clamp(speed * 0.1, 0, 3)
                local chaosX = math.sin(timeAccum * 2.1 + data.phase) * chaosFactor
                local chaosZ = math.cos(timeAccum * 1.9 + data.phase * 1.3) * chaosFactor
                local chaosY = math.sin(timeAccum * 2.7 + data.phase * 2.3) * chaosFactor * 0.5
                
                local offset = Vector3.new(orbitX + chaosX, verticalOffset + chaosY, orbitZ + chaosZ)
                if speed > 5 then
                    offset = offset + (-dir * clamp(speed * 0.08, 0, 3))
                end
                
                local targetPos = predictedPos + offset
                
                if data.targetAttachment and data.targetAttachment.Parent then
                    pcall(function() data.targetAttachment.Parent.Position = targetPos end)
                end
            else
                if not data.switchingLock then
                    data.switchingLock = true
                    spawn(function()
                        wait(0.1)
                        if data and nightmareMode then reassignNightmarePart(part) end
                        if data then data.switchingLock = false end
                    end)
                end
            end
            
            -- Periodic target switching
            if timeAccum >= data.nextSwitchTime then
                if not data.switchingLock then
                    data.switchingLock = true
                    spawn(function()
                        wait(0.05)
                        if data and nightmareMode then reassignNightmarePart(part) end
                        if data then
                            data.switchingLock = false
                            data.nextSwitchTime = timeAccum + INDIVIDUAL_SWITCH_INTERVAL_BASE + (math.random() * INDIVIDUAL_SWITCH_INTERVAL_VARY)
                        end
                    end)
                end
            end
        end
    end)
end

local function startNightmareFling()
    if not enabled then return end
    nightmareIndividualPartsData = {}
    
    for _, v in ipairs(Workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("BasePart") and not v.Anchored and v.Name ~= "Handle"
                and not isPlayerPart(v)
                and not (localPlayer.Character and v:IsDescendantOf(localPlayer.Character))
                and (mainFunnelSet[v] or whitelistedParts[v]) then
                
                local data = createNightmareAttachmentForPart(v, getRandomTargetPlayer())
                if data then
                    startNightmarePartThread(v, data)
                end
            end
        end)
    end
    
    -- Continuously find new parts
    spawn(function()
        while nightmareMode and enabled do
            for _, v in ipairs(Workspace:GetDescendants()) do
                pcall(function()
                    if nightmareMode and enabled and v:IsA("BasePart") and not v.Anchored
                        and not nightmareIndividualPartsData[v]
                        and (mainFunnelSet[v] or whitelistedParts[v]) then
                        
                        local data = createNightmareAttachmentForPart(v, getRandomTargetPlayer())
                        if data then
                            startNightmarePartThread(v, data)
                        end
                    end
                end)
            end
            wait(0.5)
        end
    end)
end

local function stopNightmareFling()
    for part, data in pairs(nightmareIndividualPartsData) do
        pcall(function()
            if part and part.Parent then
                stripBodyForces(part)
                part.CanCollide = false
            end
            if data.targetAttachment and data.targetAttachment.Parent then
                pcall(function() data.targetAttachment.Parent:Destroy() end)
            end
        end)
    end
    nightmareIndividualPartsData = {}
end

-- ========== ROPE TORNADO ==========
local function wrapAngle(a)
    local twoPi = 2 * math.pi
    return ((a % twoPi) + twoPi) % twoPi
end

local function shortestAngleDiff(a, b)
    local diff = (b - a) % (2 * math.pi)
    if diff > math.pi then diff = diff - 2 * math.pi end
    return diff
end

local function getRopeAngleState(idx)
    if not ropeAngleStates[idx] then
        ropeAngleStates[idx] = {
            currentAngle = math.random() * 2 * math.pi,
            targetAngle = 0,
            lastChangeTime = os.clock(),
            transitioning = false,
            transitionStart = 0,
            transitionTime = 1.5 + math.random() * 0.5
        }
        ropeAngleStates[idx].targetAngle = ropeAngleStates[idx].currentAngle
    end
    return ropeAngleStates[idx]
end

local function ropePickNewTargetAngle(state)
    state.targetAngle = math.random() * 2 * math.pi
    state.transitionStart = os.clock()
    state.transitioning = true
end

local function ropeUpdateAngleForState(state)
    local now = os.clock()
    if not state.transitioning and now - state.lastChangeTime >= ropeHoldDuration then
        ropePickNewTargetAngle(state)
        state.lastChangeTime = now
    end
    if state.transitioning then
        local alpha = math.clamp((now - state.transitionStart) / state.transitionTime, 0, 1)
        local diff = shortestAngleDiff(state.currentAngle, state.targetAngle)
        state.currentAngle = wrapAngle(state.currentAngle + diff * alpha)
        if alpha >= 1 then state.transitioning = false end
    end
end

local function ropeSafeVelocity(part, vel)
    if not part or not part.Parent then return end
    if vel.Magnitude > ropeMaxVelocityMag then vel = vel.Unit * ropeMaxVelocityMag end
    pcall(function()
        part.AssemblyLinearVelocity = vel
        part.CanCollide = false
    end)
end

local function applyRopeTornadoAtPos(rootPos, angleState)
    ropeUpdateAngleForState(angleState)
    
    local t = os.clock()
    local wiggleX = math.sin(t * 1.2 + angleState.currentAngle) * ropeMovementIntensity
    local wiggleZ = math.cos(t * 0.9 + math.sin(t * 0.3) + angleState.currentAngle) * ropeMovementIntensity
    local sideX = math.cos(angleState.currentAngle) * ropeFunnelSidewaysReach + wiggleX
    local sideZ = math.sin(angleState.currentAngle) * ropeFunnelSidewaysReach + wiggleZ
    local topOffset = Vector3.new(sideX, tornadoWindfield * 0.3, sideZ)
    
    local funnelTop = rootPos + topOffset
    local funnelBottom = rootPos
    local axisVec = funnelBottom - funnelTop
    local axisLen = axisVec.Magnitude
    if axisLen <= 0 then return end
    
    local parts = Workspace:GetPartBoundsInRadius(rootPos, tornadoWindfield)
    for _, part in ipairs(parts) do
        if part:IsA("BasePart") and not part.Anchored and not isPlayerPart(part) and part.Name ~= baseplateName then
            local mass = part:GetMass()
            if mass < ropeMaxPartMass then
                local ab = funnelBottom - funnelTop
                local denom = ab:Dot(ab)
                local rel = denom > 0 and math.clamp((part.Position - funnelTop):Dot(ab) / denom, 0, 1) or 0
                local closestPoint = funnelTop + ab * rel
                
                local radiusAt = ropeTopRadius * (1 - rel) + tornadoWindfield * rel
                local offset = part.Position - closestPoint
                local horizontal = Vector3.new(offset.X, 0, offset.Z)
                local dist = horizontal.Magnitude
                local reachTolerance = 40
                
                if dist <= radiusAt + reachTolerance then
                    local radialDir = (horizontal.Magnitude > 0 and -horizontal.Unit or Vector3.zero)
                    local radialPull = radialDir * ropeInwardPullSpeed
                    local spinDir = Vector3.new(-horizontal.Z, 0, horizontal.X)
                    if spinDir.Magnitude > 0 then spinDir = spinDir.Unit end
                    local tangential = spinDir * tornadoSpinSpeed
                    local upward = Vector3.new(0, tornadoUpwardSpeed, 0)
                    local vel = tangential + radialPull + upward
                    ropeSafeVelocity(part, vel)
                end
            end
        end
    end
end

local function setupRopeTornado()
    for part in pairs(ropeParts) do
        if part and part.Parent then
            part.AssemblyLinearVelocity = Vector3.zero
            part.CanCollide = true
        end
        ropeParts[part] = nil
    end
    ropeLines = {}
    ropeSegments = {}
    ropeAngleStates = {}
    ropeActualCenters = {}
end

-- ========== PER-TORNADO INDEPENDENT PATH SYSTEM ==========
local function pickRandomTargetForTornado(idx, playerPos)
    local angle = math.random() * math.pi * 2
    local dist = math.random(50, math.min(1500, randomMaxDistance))
    local target = playerPos + Vector3.new(math.cos(angle) * dist, 0, math.sin(angle) * dist)
    tornadoPathTargets[idx] = {
        target = target,
        switchTimer = tick() + math.random(5, 20),
        startPos = nil,
        progress = 0
    }
    return target
end

local function pickStalkTargetForTornado(idx)
    local nonLocal = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= localPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            table.insert(nonLocal, plr)
        end
    end
    if #nonLocal > 0 then
        tornadoStalkTargets[idx] = nonLocal[math.random(1, #nonLocal)]
    end
end

local function computeTornadoTargetPosition(idx, basePos, multiCount)
    if pathType == "Follow" then
        if multiCount and multiCount >= 2 then
            local orbitSpeed = 2
            local time = tick() * orbitSpeed
            local angleOffset = (idx - 1) * (2 * math.pi / multiCount)
            local spreadRadius = math.clamp(tornadoWindfield * 0.12 * math.sqrt(multiCount), 10, tornadoWindfield * 0.35)
            local angle = time + angleOffset
            return basePos + Vector3.new(math.cos(angle) * spreadRadius, 0, math.sin(angle) * spreadRadius)
        else
            return basePos
        end
    elseif pathType == "Random" then
        local state = tornadoPathTargets[idx]
        if not state or tick() > state.switchTimer then
            local currentPos = tornadoPositions[idx] or basePos
            pickRandomTargetForTornado(idx, basePos)
            state = tornadoPathTargets[idx]
            state.startPos = currentPos
            state.progress = 0
        end
        
        if not state.startPos then
            state.startPos = tornadoPositions[idx] or basePos
            state.progress = 0
        end
        
        local targetPos = state.target
        if not targetPos then return basePos end
        
        local totalDist = (targetPos - state.startPos).Magnitude
        if totalDist < 1 then return targetPos end
        
        local speedPerFrame = tornadoRandomPathSpeed * 0.06
        state.progress = state.progress + (speedPerFrame / totalDist)
        
        if state.progress >= 1 then
            state.progress = 1
            state.switchTimer = tick() + math.random(2, 5)
            return targetPos
        end
        
        local currentPos = state.startPos:Lerp(targetPos, state.progress)
        
        local fromPlayer = currentPos - basePos
        if fromPlayer.Magnitude > randomMaxDistance then
            currentPos = basePos + fromPlayer.Unit * (randomMaxDistance - 10)
        end
        
        return currentPos
    elseif pathType == "Stalker" then
        local stalk = tornadoStalkTargets[idx]
        if not stalk or not stalk.Character or not stalk.Character:FindFirstChild("HumanoidRootPart") then
            pickStalkTargetForTornado(idx)
            stalk = tornadoStalkTargets[idx]
        end
        if math.random() < 0.005 then
            pickStalkTargetForTornado(idx)
            stalk = tornadoStalkTargets[idx]
        end
        if stalk and stalk.Character and stalk.Character:FindFirstChild("HumanoidRootPart") then
            return stalk.Character.HumanoidRootPart.Position + Vector3.new(0, 5, 0)
        end
        return basePos
    end
    return basePos
end

local function updatePositions()
    local root = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local basePos = root.Position
    local count = math.max(1, tornadoAmount)
    
    for i = 1, count do
        if tornadoPositions[i] then
            prevTornadoPositions[i] = tornadoPositions[i]
        end
    end
    
    if pathType == "Follow" then
        if count >= 2 then
            local orbitSpeed = 2
            local elapsed = tick() * orbitSpeed
            local spreadRadius = math.clamp(tornadoWindfield * 0.12 * math.sqrt(count), 15, tornadoWindfield * 0.35)
            for i = 1, count do
                local angle = elapsed + (i - 1) * (2 * math.pi / count)
                tornadoPositions[i] = basePos + Vector3.new(math.cos(angle) * spreadRadius, 0, math.sin(angle) * spreadRadius)
            end
        else
            tornadoPositions[1] = basePos
        end
    elseif pathType == "Random" then
        local time = tick() * 0.15
        for i = 1, count do
            local angle = (i - 1) * (2 * math.pi / count) + time
            local spread = math.clamp(tornadoWindfield * 0.12 * math.sqrt(count), 10, tornadoWindfield * 0.35)
            local formationOffset = Vector3.new(math.cos(angle) * spread, 0, math.sin(angle) * spread)
            
            local individualTarget = computeTornadoTargetPosition(i, basePos, count)
            
            local targetPos = basePos + formationOffset
            local toIndividual = individualTarget - targetPos
            if toIndividual.Magnitude > 1 then
                targetPos = targetPos + toIndividual.Unit * math.min(toIndividual.Magnitude, spread * 0.5)
            end
            
            tornadoPositions[i] = targetPos
        end
    elseif pathType == "Stalker" then
        local centerTarget = basePos
        for i = 1, count do
            local stalk = tornadoStalkTargets[i]
            if stalk and stalk.Character and stalk.Character:FindFirstChild("HumanoidRootPart") then
                centerTarget = stalk.Character.HumanoidRootPart.Position
                break
            end
        end
        
        local time = tick() * 0.15
        for i = 1, count do
            local angle = (i - 1) * (2 * math.pi / count) + time
            local spread = math.clamp(tornadoWindfield * 0.12 * math.sqrt(count), 10, tornadoWindfield * 0.35)
            local formationOffset = Vector3.new(math.cos(angle) * spread, 0, math.sin(angle) * spread)
            
            local individualTarget = computeTornadoTargetPosition(i, basePos, count)
            local targetPos = centerTarget + formationOffset
            local toIndividual = individualTarget - targetPos
            if toIndividual.Magnitude > 1 then
                targetPos = targetPos + toIndividual.Unit * math.min(toIndividual.Magnitude, spread * 0.5)
            end
            
            tornadoPositions[i] = targetPos
        end
    end
    
    if tornadoType == "Rope" then
        for i = 1, #tornadoPositions do
            if not ropeActualCenters[i] then
                ropeActualCenters[i] = tornadoPositions[i]
            end
            
            local dir = tornadoPositions[i] - ropeActualCenters[i]
            local dist = dir.Magnitude
            if dist > 0.5 then
                local speed = math.max(tornadoMoveSpeed * 0.5, dist * 1.5)
                local step = math.min(dist, speed * 0.06)
                ropeActualCenters[i] = ropeActualCenters[i] + dir.Unit * step
            else
                ropeActualCenters[i] = tornadoPositions[i]
            end
        end
    end
end

local function tornadoLoop()
    while enabled do
        updatePositions()
        
        if #tornadoPositions > 0 then
            if tornadoType == "Rope" then
                for i = 1, #tornadoPositions do
                    local center = ropeActualCenters[i]
                    if center then
                        local angleState = getRopeAngleState(i)
                        applyRopeTornadoAtPos(center, angleState)
                    end
                end
            else
                updateMainFunnel(0.1)
                for _, pos in ipairs(tornadoPositions) do
                    applyTornadoPhysics(pos, 0.1)
                end
            end
        end
        task.wait(0.06)
    end
end

-- ========== SATELLITE SYSTEM ==========
local function createSatelliteMarker(sat)
    if sat.marker and sat.marker.Parent then return end
    local m = Instance.new("Part")
    m.Name = "SatelliteMarker"
    m.Size = Vector3.new(1,1,1)
    m.Anchored = true
    m.CanCollide = false
    m.Material = Enum.Material.Neon
    m.Transparency = 0
    m.Color = Color3.fromRGB(255, 100, 100)
    m.Parent = Workspace
    sat.marker = m
end

local function removeSatelliteMarker(sat)
    if sat and sat.marker and sat.marker.Parent then
        pcall(function() sat.marker:Destroy() end)
        sat.marker = nil
    end
end

local function spawnSatelliteWithParts(pos, partsList, idOverride)
    local id = idOverride or nextSatelliteId
    if not idOverride then nextSatelliteId = nextSatelliteId + 1 end
    local partsMap = {}
    for _, p in ipairs(partsList) do
        if p and p.Parent then
            local radius = subVortexWidth * (0.3 + math.random() * 0.7)
            local speed = subVortexSpinSpeed * (1 + (math.random()*0.6 - 0.3))
            partsMap[p] = {
                radius=radius,
                speed=speed,
                phase=math.random()*math.pi*2,
                floorOffset=2+math.random()*2,
                topOffset=subVortexHeight+math.random()*4,
                verticalTarget=nil,
                currentY=nil
            }
            assignedToSatellite[p] = id
        end
    end
    satelliteVortices[id] = {
        id=id,
        pos=pos,
        angleOffset=0,
        parts=partsMap,
        target=nil,
        verticalChains={},
        lastVortexSpawnTick=tick(),
        marker=nil
    }
    satelliteAttackState[id] = {attackingPlayers={}, attackThreads={}}
    local partCount = 0
    for _,_ in pairs(partsMap) do partCount = partCount + 1 end
    if partCount == 0 then createSatelliteMarker(satelliteVortices[id]) end
    return id
end

local function despawnSatellite(id)
    local sat = satelliteVortices[id]
    if not sat then return end
    for part, _ in pairs(sat.parts) do
        if part and part.Parent then
            assignedToSatellite[part] = nil
            whitelistedParts[part] = true
            pickedUpByFunnel[part] = true
            part.CanCollide = true
        end
    end
    removeSatelliteMarker(sat)
    satelliteVortices[id] = nil
    satelliteAttackState[id] = nil
    noodlePools[id] = nil
end

local function formSatellitesInstant()
    if tornadoType == "Rope" then
        for id, _ in pairs(satelliteVortices) do despawnSatellite(id) end
        setupRopeTornado()
        return
    end
    
    for id, _ in pairs(satelliteVortices) do despawnSatellite(id) end
    
    local count = math.max(0, maxSubVortices)
    if count == 0 then return end
    
    local spawnCenter = tornadoPositions[1] or (localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") and localPlayer.Character.HumanoidRootPart.Position) or Vector3.new(0,10,0)
    local allParts = Workspace:GetPartBoundsInRadius(spawnCenter, tornadoWindfield)
    local candidateParts = {}
    for _, p in ipairs(allParts) do
        if p and p:IsA("BasePart") and not p.Anchored and not isPlayerPart(p) and p.Name ~= baseplateName and not assignedToSatellite[p] and not noodlePartSet[p] and not mainFunnelSet[p] and not ropeParts[p] then
            table.insert(candidateParts, p)
        end
    end
    
    local total = #candidateParts
    table.sort(candidateParts, function(a,b) return (a.Position - spawnCenter).Magnitude < (b.Position - spawnCenter).Magnitude end)
    
    local desiredByShare = math.floor(total * mainFunnelShare + 0.5)
    local mainReserve = math.clamp(desiredByShare, 0, total)
    local remainingCount = total - mainReserve
    while remainingCount < count and mainReserve > math.min(funnelReserveCount, total) do
        mainReserve = mainReserve - 1
        remainingCount = total - mainReserve
    end
    mainReserve = math.clamp(mainReserve, 0, total)
    
    mainFunnelParts = {}
    mainFunnelSet = {}
    for i = 1, mainReserve do
        local p = candidateParts[i]
        if p then
            mainFunnelParts[#mainFunnelParts+1] = p
            mainFunnelSet[p] = true
            assignedToSatellite[p] = nil
            whitelistedParts[p] = nil
            pickedUpByFunnel[p] = nil
        end
    end
    
    local remainingParts = {}
    for i = mainReserve + 1, #candidateParts do
        remainingParts[#remainingParts+1] = candidateParts[i]
    end
    
    local partitions = {}
    for i = 1, count do partitions[i] = {} end
    
    if #remainingParts > 0 then
        local idx = 1
        for _, p in ipairs(remainingParts) do
            local slot = ((idx - 1) % count) + 1
            table.insert(partitions[slot], p)
            assignedToSatellite[p] = true
            whitelistedParts[p] = nil
            pickedUpByFunnel[p] = nil
            idx = idx + 1
        end
    end
    
    local orbitRad = subVortexWidth * 0.5
    for i = 1, count do
        local angle = (2 * math.pi * (i - 1) / count)
        local pos = spawnCenter + Vector3.new(math.cos(angle) * orbitRad, 10 + math.random()*6, math.sin(angle) * orbitRad)
        spawnSatelliteWithParts(pos, partitions[i] or {})
        local newId = nextSatelliteId - 1
        if satelliteVortices[newId] then
            satelliteVortices[newId].angleOffset = angle
        end
    end
end

local function updateSatellites(delta)
    if tornadoType == "Rope" or #tornadoPositions == 0 then return end
    local centerPos = tornadoPositions[1]
    for id, sat in pairs(satelliteVortices) do
        sat.angleOffset = sat.angleOffset + (0.5 * delta)
        local orbitRad = math.clamp(subVortexWidth * 0.3, 6, subVortexWidth)
        local newPos = centerPos + Vector3.new(math.cos(sat.angleOffset) * orbitRad, 10, math.sin(sat.angleOffset) * orbitRad)
        local dir = (newPos - sat.pos)
        sat.pos = sat.pos + dir * math.min(1, delta * 2)
        
        if sat.marker then
            pcall(function() sat.marker.CFrame = CFrame.new(sat.pos + Vector3.new(0,2,0)) end)
        end
        
        for part, meta in pairs(sat.parts) do
            if part and part.Parent then
                local angle = (tick() * meta.speed) + meta.phase
                local radiusPulse = meta.radius * (1 + 0.06 * math.sin(tick() * 0.5 + meta.phase))
                local horizTarget = sat.pos + Vector3.new(math.cos(angle) * radiusPulse, 0, math.sin(angle) * radiusPulse)
                local floorY = centerPos.Y + (meta.floorOffset or 2)
                local topY = centerPos.Y + (meta.topOffset or subVortexHeight)
                
                if not meta.currentY then
                    meta.currentY = math.clamp(part.Position.Y, floorY, topY)
                end
                if not meta.verticalTarget then
                    meta.verticalTarget = (floorY + topY) / 2
                end
                if math.abs(meta.currentY - meta.verticalTarget) < 0.5 then
                    meta.verticalTarget = floorY + math.random() * (math.max(1, topY - floorY))
                end
                
                local interpSpeed = math.max(0.15, (meta.speed or 1) * 0.25)
                meta.currentY = meta.currentY + (meta.verticalTarget - meta.currentY) * math.clamp(delta * interpSpeed, 0, 1)
                local targetPos = Vector3.new(horizTarget.X, meta.currentY, horizTarget.Z)
                
                if not part.Anchored then
                    local desiredVel = (targetPos - part.Position) / math.max(delta, 0.016)
                    local maxVel = math.max(orbitVelocityMinCap, math.abs(radiusPulse * meta.speed * orbitVelocityMultiplier))
                    if desiredVel.Magnitude > maxVel then
                        desiredVel = desiredVel.Unit * maxVel
                    end
                    local smoothFactor = math.min(1, delta * 8)
                    part.AssemblyLinearVelocity = part.AssemblyLinearVelocity:Lerp(Vector3.new(desiredVel.X, math.clamp(desiredVel.Y, -140, 140), desiredVel.Z), smoothFactor)
                    part.CanCollide = false
                end
                
                if part.Position.Y >= (centerPos.Y + funnelHeight) and not debrisAttachedToPlayer[part] then
                    snapPartDown(part, centerPos.Y)
                end
            else
                sat.parts[part] = nil
            end
        end
    end
end

