local function toggleFreeze()
    partsFrozen = not partsFrozen
    freezeBtn.Text = partsFrozen and "Unfreeze" or "Freeze"
    freezeBtn.BackgroundColor3 = partsFrozen and Color3.fromRGB(100, 80, 40) or Color3.fromRGB(60, 60, 70)
    
    if partsFrozen then
        frozenParts = {}
        for part in pairs(whitelistedParts) do
            if part and part.Parent then
                frozenParts[part] = part.Anchored
                part.Anchored = true
            end
        end
        for _, p in ipairs(mainFunnelParts) do
            if p and p.Parent then
                frozenParts[p] = p.Anchored
                p.Anchored = true
            end
        end
        for part in pairs(ropeParts) do
            if part and part.Parent then
                frozenParts[part] = part.Anchored
                part.Anchored = true
            end
        end
        for _, sat in pairs(satelliteVortices) do
            for part, _ in pairs(sat.parts) do
                if part and part.Parent then
                    frozenParts[part] = part.Anchored
                    part.Anchored = true
                end
            end
        end
    else
        for part, wasAnchored in pairs(frozenParts) do
            if part and part.Parent then
                part.Anchored = wasAnchored
            end
        end
        frozenParts = {}
    end
end

