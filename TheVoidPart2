	sg.Parent = playerGui

	local frame = Instance.new("Frame")
	frame.Name = "Frame"
	frame.Parent = sg
	frame.Size = UDim2.new(0, 220, 0, 124)
	frame.Position = UDim2.new(0.5, -110, 0, 8)
	frame.BackgroundTransparency = 0.2
	frame.BackgroundColor3 = Color3.fromRGB(20,20,20)
