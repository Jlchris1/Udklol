local function enterSoftDomain(btnToggle, btnReturn)
	local char = localPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then return end

	softDomainActive = true
	setSoftButtonText(btnToggle)
	setReturnButtonVisible(btnReturn)
	updateTravelButtonText()

	softState.originalTime = Lighting and Lighting.ClockTime or nil
	pcall(function() Lighting.ClockTime = 2 end)

	if softState.createdFolder and softState.createdFolder.Parent then
		pcall(function() softState.createdFolder:Destroy() end)
	end
	softState.createdFolder = createDomainBox()

	softState.playerOriginalCFrame = hrp.CFrame
	softState.playerOriginalPlatformStand = hum.PlatformStand
	softState.playerOriginalWalk = hum.WalkSpeed
	softState.playerOriginalJump = hum.JumpPower or 0
	pcall(function() softState.playerHRPCanCollide = hrp.CanCollide end)

	local playerPos = hrp.Position
	local nearby = collectNPCsAround(playerPos, DOMAIN_RADIUS)

	for _, item in ipairs(nearby) do
		local model = item.model
		if model and model.Parent then
			local rec = softState.npcRecords[model]
			if not rec then
				rec = captureModelRecord(model)
				if rec then
					softState.npcRecords[model] = rec
					applyStun(rec, true)
					rec.softTouched = true
				end
			else
				unanchorButKeepStunned(rec)
				rec.softTouched = true
			end
		end
	end

	local liftAnchor = Instance.new("Part")
	liftAnchor.Name = "SoftDomainAnchor_" .. tostring(tick())
	liftAnchor.Size = Vector3.new(1,1,1)
	liftAnchor.Anchored = true
	liftAnchor.CanCollide = false
	liftAnchor.Transparency = 1
	liftAnchor.CFrame = hrp.CFrame
	liftAnchor.Parent = Workspace
	softState.entryAnchor = liftAnchor

	local start = liftAnchor.Position
	local target = start + Vector3.new(0, DOMAIN_ENTRY_LIFT, 0)
	local elapsed = 0

	while elapsed < DOMAIN_ENTRY_LIFT_TIME do
		local dt = RunService.Heartbeat:Wait()
		elapsed = elapsed + dt
		local alpha = math.clamp(elapsed / DOMAIN_ENTRY_LIFT_TIME, 0, 1)
		local newPos = start:Lerp(target, alpha)
		liftAnchor.Position = newPos
		if hrp and hrp.Parent then
			pcall(function() hrp.CFrame = CFrame.new(newPos) end)
		end
	end

	if hrp and hrp.Parent then
		pcall(function() hrp.CFrame = CFrame.new(DOMAIN_BOX_WORLD_POS + Vector3.new(0, 10, 0)) end)
		clearVelocityPeriodic(hrp, CLEAR_VEL_INTERVAL, CLEAR_VEL_DURATION)
	end

	restorePlayerStateFrom(softState, hrp, hum)
end

local function exitSoftDomain(btnToggle, btnReturn)
	local char = localPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then
		softDomainActive = false
		setSoftButtonText(btnToggle)
		setReturnButtonVisible(btnReturn)
		return
	end

	if softState.entryAnchor and softState.entryAnchor.Parent then
		pcall(function() softState.entryAnchor:Destroy() end)
	end
	softState.entryAnchor = nil

	local start = hrp.Position
	local target = start + Vector3.new(0, DOMAIN_FLOAT_HEIGHT, 0)
	local anchor = Instance.new("Part")
	anchor.Name = "SoftExitAnchor_" .. tostring(tick())
	anchor.Size = Vector3.new(1,1,1)
	anchor.Anchored = true
	anchor.CanCollide = false
	anchor.Transparency = 1
	anchor.Position = start
	anchor.Parent = Workspace

	local elapsed = 0
	while elapsed < DOMAIN_FLOAT_TIME do
		local dt = RunService.Heartbeat:Wait()
		elapsed = elapsed + dt
		local alpha = math.clamp(elapsed / DOMAIN_FLOAT_TIME, 0, 1)
		anchor.Position = start:Lerp(target, alpha)
		if hrp and hrp.Parent then
			pcall(function() hrp.CFrame = CFrame.new(anchor.Position) end)
		end
	end

	-- Ditch NPCs where they are: they remain anchored/stunned.
	for model, rec in pairs(softState.npcRecords) do
		if rec and rec.model and rec.model.Parent then
			applyStun(rec, true)
		end
	end

	if hrp and hrp.Parent then
		pcall(function() hrp.CFrame = softState.playerOriginalCFrame or hrp.CFrame end)
		clearVelocityPeriodic(hrp, CLEAR_VEL_INTERVAL, CLEAR_VEL_DURATION)
	end

	if softState.createdFolder then
		destroyDomainBox(softState.createdFolder)
		softState.createdFolder = nil
	end

	if softState.originalTime then
		pcall(function() Lighting.ClockTime = softState.originalTime end)
		softState.originalTime = nil
	end

	if anchor and anchor.Parent then pcall(function() anchor:Destroy() end) end
	softDomainActive = false
	setSoftButtonText(btnToggle)
	setReturnButtonVisible(btnReturn)
	restorePlayerStateFrom(softState, hrp, hum)
end

local function returnEverything(btnReturn)
	local playerChar = localPlayer.Character
	local hrp = playerChar and playerChar:FindFirstChild("HumanoidRootPart")
	local hum = playerChar and playerChar:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then return end

	local activeRecords = {}
	local state = nil

	if domainActive and next(domainState.npcRecords) ~= nil then
		state = domainState
		for model, rec in pairs(domainState.npcRecords) do
			if rec then table.insert(activeRecords, rec) end
		end
	elseif softDomainActive and next(softState.npcRecords) ~= nil then
		state = softState
		for model, rec in pairs(softState.npcRecords) do
			if rec then table.insert(activeRecords, rec) end
		end
	else
		return
	end

	local floatAnchor = Instance.new("Part")
	floatAnchor.Name = "ReturnEverythingAnchor_" .. tostring(tick())
	floatAnchor.Size = Vector3.new(1,1,1)
	floatAnchor.Anchored = true
	floatAnchor.CanCollide = false
	floatAnchor.Transparency = 1
	floatAnchor.CFrame = hrp.CFrame
	floatAnchor.Parent = Workspace

	local playerStart = hrp.Position
	for _, rec in ipairs(activeRecords) do
		if rec and rec.root and rec.root.Parent then
			rec.floatOffset = rec.root.Position - playerStart
		end
	end

	local start = floatAnchor.Position
	local target = start + Vector3.new(0, DOMAIN_ENTRY_LIFT, 0)
	local elapsed = 0
	while elapsed < DOMAIN_ENTRY_LIFT_TIME do
		local dt = RunService.Heartbeat:Wait()
		elapsed = elapsed + dt
		local alpha = math.clamp(elapsed / DOMAIN_ENTRY_LIFT_TIME, 0, 1)
		local newPos = start:Lerp(target, alpha)
		floatAnchor.Position = newPos
		if hrp and hrp.Parent then
			pcall(function() hrp.CFrame = CFrame.new(newPos) end)
		end
		for _, rec in ipairs(activeRecords) do
			if rec and rec.model and rec.model.Parent and rec.floatOffset then
				local targetRootPos = newPos + rec.floatOffset
				for part, localCF in pairs(rec.partLocalCFrames or {}) do
					if part and part.Parent then
						local desired = CFrame.new(targetRootPos) * localCF
						pcall(function()
							part.CFrame = part.CFrame:Lerp(desired, alpha)
							if part.AssemblyLinearVelocity then part.AssemblyLinearVelocity = Vector3.new(0,0,0) end
							if part.AssemblyAngularVelocity then part.AssemblyAngularVelocity = Vector3.new(0,0,0) end
						end)
					end
				end
			end
		end
	end

	for _, rec in ipairs(activeRecords) do
		restoreModelFromRecord(rec, false)
	end

	if state and state.playerOriginalCFrame then
		pcall(function() hrp.CFrame = state.playerOriginalCFrame end)
	end
	restorePlayerStateFrom(state or softState, hrp, hum)

	if floatAnchor and floatAnchor.Parent then pcall(function() floatAnchor:Destroy() end) end
	setReturnButtonVisible(btnReturn)
	updateTravelButtonText()
end

