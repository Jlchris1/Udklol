-- Wire the tool
local function wireVoidTool(tool)
	if not tool or not tool:IsA("Tool") then return end
	if tool:FindFirstChild("__VoidWired") then return end

	local marker = Instance.new("BoolValue")
	marker.Name = "__VoidWired"
	marker.Parent = tool

	local guiSG, domainBtn, sendAllBtn, killReturnBtn, soloReturnBtn, soloEnterBtn
	local mouse
	local clickConn
	local domainBtnConn, sendAllConn, killReturnBtnConn, soloReturnBtnConn, soloEnterBtnConn

	local function onUnequip()
		if clickConn then clickConn:Disconnect(); clickConn = nil end
		if domainBtnConn then domainBtnConn:Disconnect(); domainBtnConn = nil end
		if sendAllConn then sendAllConn:Disconnect(); sendAllConn = nil end
		if killReturnBtnConn then killReturnBtnConn:Disconnect(); killReturnBtnConn = nil end
		if soloReturnBtnConn then soloReturnBtnConn:Disconnect(); soloReturnBtnConn = nil end
		if soloEnterBtnConn then soloEnterBtnConn:Disconnect(); soloEnterBtnConn = nil end
		if guiSG and guiSG.Parent then guiSG.Enabled = false end
	end

	tool.Equipped:Connect(function(m)
		mouse = m or localPlayer:GetMouse()
		guiSG, domainBtn, sendAllBtn, killReturnBtn, soloReturnBtn, soloEnterBtn = createVoidGUI(tool)
		if guiSG then guiSG.Enabled = true end

		if domainBtn then
			domainBtnConn = domainBtn.MouseButton1Click:Connect(function()
				if domainActive then
					exitDomainByClick()
					return
				end

				local char = localPlayer.Character
				local pr = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso"))
				if not pr then return end

				domainActive = true
				refreshVoidDomainActive()

				domainState.originalTime = Lighting and Lighting.ClockTime or nil
				pcall(function() Lighting.ClockTime = 2 end)

				local npcList = {}
				for _, desc in ipairs(Workspace:GetDescendants()) do
					if desc:IsA("Humanoid") then
						local model = desc.Parent
						if model and isNPC(model) then
							local hrp = getModelRoot(model)
							if hrp and (hrp.Position - pr.Position).Magnitude <= DOMAIN_RADIUS then
								table.insert(npcList, {hum = desc, model = model, hrp = hrp})
							end
						end
					end
				end

				local boxFolder = createDomainBox()
				domainState.createdFolder = boxFolder

				-- Solo Enter ON -> only the player enters the domain.
				-- Solo Enter OFF -> both the player and NPCs enter the domain.
				moveIntoDomain(npcList, soloEnterEnabled)

				refreshVoidDomainActive()

				-- Monitor: if local player leaves domain, close the session.
				task.spawn(function()
					while domainActive do
						RunService.Heartbeat:Wait()
						local pChar = localPlayer.Character
						local pHRP = pChar and pChar:FindFirstChild("HumanoidRootPart")
						if not pHRP or not pHRP.Parent then
							break
						end
						if not isPositionInsideDomain(pHRP.Position) then
							break
						end
					end

					if domainActive then
						-- If the player leaves and Solo Return is ON, NPCs remain trapped in void.
						-- Otherwise, they return with the player.
						cleanupNPCsOnReturn()

						if not soloReturnEnabled then
							resetDomainEnvironment()
						else
							-- Keep the void domain alive for trapped NPCs.
							if domainState.originalTime then
								pcall(function() Lighting.ClockTime = domainState.originalTime end)
							end
							domainState.originalTime = nil
							domainActive = false
							refreshVoidDomainActive()
						end
					end
				end)

				-- If all NPCs die, close the domain cleanly.
				task.spawn(function()
					local still = {}
					for _, e in ipairs(npcList) do
						if e.model and e.hum and e.hum.Parent and e.hum.Health > 0 then
							still[e.model] = e.hum
						end
					end
					if next(still) == nil then return end

					local count = 0
					local conns = {}
					for model, hum in pairs(still) do
						count = count + 1
						conns[model] = hum.Died:Connect(function()
							pcall(function()
								conns[model]:Disconnect()
							end)
							conns[model] = nil
							count = count - 1
							if count <= 0 then
								cleanupNPCsWithoutReturn()
								resetDomainEnvironment()
								domainActive = false
								refreshVoidDomainActive()
							end
						end)
					end
				end)
			end)
		end

		if sendAllBtn then
			sendAllConn = sendAllBtn.MouseButton1Click:Connect(function()
				pcall(function()
					Workspace.FallenPartsDestroyHeight = VOID_FALLEN_HEIGHT
				end)
				for _, desc in ipairs(Workspace:GetDescendants()) do
					if desc:IsA("Humanoid") then
						local model = desc.Parent
						if model and isNPC(model) then
							task.spawn(function()
								local toolToUse = toolInstance or ensureVoidTool()
								if toolToUse then
									pcall(function() sendModelToVoidWithHandle(toolToUse, model, "sendAll") end)
								else
									sendModelToVoidWithHandle(nil, model, "sendAll")
								end
								task.wait(SEND_ALL_VOID_DELAY)
							end)
						end
					end
				end
			end)
		end

		if killReturnBtn then
			killReturnBtnConn = killReturnBtn.MouseButton1Click:Connect(function()
				killReturnEnabled = not killReturnEnabled
				updateKillReturnButton(killReturnBtn)
			end)
		end

		if soloReturnBtn then
			soloReturnBtnConn = soloReturnBtn.MouseButton1Click:Connect(function()
				soloReturnEnabled = not soloReturnEnabled
				updateSoloReturnButton(soloReturnBtn)
			end)
		end

		if soloEnterBtn then
			soloEnterBtnConn = soloEnterBtn.MouseButton1Click:Connect(function()
				soloEnterEnabled = not soloEnterEnabled
				updateSoloEnterButton(soloEnterBtn)
			end)
		end

		-- CLICK HANDLER: Send to void immediately, do NOT trigger domain.
		clickConn = mouse.Button1Down:Connect(function()
			local x, y = mouse.X, mouse.Y
			local hum, model = screenRayFindHumanoid(x, y, 2000, 10)

			if not hum or not model then
				local tgt = mouse.Target
				if tgt then
					local node = tgt
					for _ = 1, 10 do
						if not node then break end
						local h = node:FindFirstChildOfClass("Humanoid")
						if h and isNPC(h.Parent) then
							hum, model = h, h.Parent
							break
						end
						node = node.Parent
					end
				end
			end

			if not hum or not model then return end

			local toolToUse = toolInstance or ensureVoidTool()
			if toolToUse then
				pcall(function()
					sendModelToVoidWithHandle(toolToUse, model, "click")
				end)
			else
				pcall(function()
					sendModelToVoidWithHandle(nil, model, "click")
				end)
			end

			trackedVoidSelections[model] = hum
			trackSelectionAndRestoreOnDeaths(trackedVoidSelections)
		end)
	end)

	tool.Unequipped:Connect(onUnequip)
end

