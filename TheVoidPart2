		b.Font = Enum.Font.SourceSansBold
		b.TextSize = 16
		b.TextColor3 = Color3.new(1,1,1)
		b.BackgroundTransparency = 0
		b.BackgroundColor3 = Color3.fromRGB(35,35,35)
		b.BorderSizePixel = 0
		b.Text = text
		b.Name = name
		b.Parent = frame
		return b
	end

	local btn = makeButton(DOMAIN_BUTTON_NAME, 6, "Void's Domain")
	local btn2 = makeButton(SECOND_BUTTON_NAME, 34, "Send All to Void")
	local btn3 = makeButton(TOGGLE_BUTTON_NAME, 62, "Go to domain")
	local btn4 = makeButton(RETURN_BUTTON_NAME, 90, "Return Everything")
