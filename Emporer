local function getToolHandle(tool)
	if not tool or not tool:IsA("Tool") then
		return nil
	end
	local h = tool:FindFirstChild("Handle")
	if h and h:IsA("BasePart") then
		return h
	end
	return nil
end

local function createTempHandleForTool(tool)
	if not tool or not tool:IsA("Tool") then return nil end

	local existing = getToolHandle(tool)
	if existing then
		if existing:GetAttribute("EmpHandlePersistent") then
			return existing
		end
		if existing:GetAttribute("EmpHandleTemp") then
			return existing
		end
		pcall(function() existing:Destroy() end)
	end

	local handle = Instance.new("Part")
	handle.Name = "Handle"
	handle.Size = Vector3.new(1, 1, 1)
	handle.Transparency = 0.5
	handle.CanCollide = false
	handle.Massless = true
	handle:SetAttribute("EmpHandleTemp", true)
	handle.Parent = tool
	return handle
end

local function removeTempHandleForTool(tool)
	if not tool or not tool:IsA("Tool") then return end
	local h = getToolHandle(tool)
	if not h then return end
	if h:GetAttribute("EmpHandlePersistent") then
		return
	end
	if h:GetAttribute("EmpHandleTemp") or h:GetAttribute("EmpHandleTempToken") then
		pcall(function() h:Destroy() end)
	end
end

local function ensurePersistentHandle(tool)
	if not tool or not tool:IsA("Tool") then return nil end
	local handle = getToolHandle(tool)
	if not handle then
		handle = Instance.new("Part")
		handle.Name = "Handle"
		handle.Size = Vector3.new(1, 1, 1)
		handle.Transparency = 0.5
		handle.CanCollide = false
		handle.Massless = true
		handle.Parent = tool
	end
	handle:SetAttribute("EmpHandlePersistent", true)
	handle:SetAttribute("EmpHandleTemp", nil)
	handle:SetAttribute("EmpHandleTempToken", nil)
	persistentHandles[tool] = handle
	return handle
end

local function removePersistentHandle(tool)
	if not tool or not tool:IsA("Tool") then return end
	local handle = persistentHandles[tool] or getToolHandle(tool)
	if handle and handle.Parent == tool and handle:GetAttribute("EmpHandlePersistent") then
		pcall(function() handle:Destroy() end)
	end
	persistentHandles[tool] = nil
end

local function removeAllPersistentHandles()
	for tool, handle in pairs(persistentHandles) do
		if handle and handle.Parent == tool and handle:GetAttribute("EmpHandlePersistent") then
			pcall(function() handle:Destroy() end)
		end
		persistentHandles[tool] = nil
	end
end

local function scheduleTempHandleRemoval(tool, seconds)
	if not tool or not tool:IsA("Tool") then return end
	local handle = createTempHandleForTool(tool)
	if not handle then return end

	local token = (tempHandleTokens[tool] or 0) + 1
	tempHandleTokens[tool] = token
	handle:SetAttribute("EmpHandleTempToken", token)

	task.delay(seconds or CLICK_TEMP_HANDLE_LIFETIME, function()
		if not tool or not tool.Parent then return end
		local h = getToolHandle(tool)
		if not h then return end
		if h:GetAttribute("EmpHandlePersistent") then return end
		if h:GetAttribute("EmpHandleTempToken") == token then
			pcall(function() h:Destroy() end)
		end
	end)
end

local function getAllOurToolInstances()
	local out = {}

	local function addTool(t)
		if t and t:IsA("Tool") then
			out[#out + 1] = t
		end
	end

	local bp = localPlayer:FindFirstChildOfClass("Backpack")
	if bp then
		addTool(bp:FindFirstChild(TOOL_EMPEROR_SLAM))
		addTool(bp:FindFirstChild(TOOL_COME_TO_ME))
		addTool(bp:FindFirstChild(TOOL_EMPEROR_POWER))
	end

	if localPlayer.Character then
		addTool(localPlayer.Character:FindFirstChild(TOOL_EMPEROR_SLAM))
		addTool(localPlayer.Character:FindFirstChild(TOOL_COME_TO_ME))
		addTool(localPlayer.Character:FindFirstChild(TOOL_EMPEROR_POWER))
	end

	return out
end

local function updateHandlesForDragState()
	if next(activeDrags) then
		for _, t in ipairs(getAllOurToolInstances()) do
			ensurePersistentHandle(t)
		end
	else
		removeAllPersistentHandles()
	end
end

