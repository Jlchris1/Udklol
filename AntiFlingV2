-- Anti Fling Toggle + Collision Protection
-- LocalScript - StarterPlayerScripts

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer


local Enabled = false

local VELOCITY_LIMIT = 300
local ANGULAR_LIMIT = 120

local ProcessedParts = {}
local CollisionConstraints = {}

local CharacterConnections = {}



-- GUI

local Gui = Instance.new("ScreenGui")
Gui.Name = "AntiFlingToggle"
Gui.ResetOnSpawn = false
Gui.Parent = LocalPlayer:WaitForChild("PlayerGui")


local Button = Instance.new("TextButton")
Button.Size = UDim2.new(0,100,0,28)
Button.Position = UDim2.new(0.5,-50,0,10)
Button.BackgroundColor3 = Color3.fromRGB(45,45,45)
Button.TextColor3 = Color3.new(1,1,1)
Button.TextScaled = true
Button.Text = "Anti OFF"
Button.Parent = Gui



-- Remove collision constraints

local function clearCollision()

	for _,c in ipairs(CollisionConstraints) do
		if c and c.Parent then
			c:Destroy()
		end
	end

	table.clear(CollisionConstraints)

end



-- Create no collision

local function createNoCollision(a,b)

	if not a or not b then return end

	local c = Instance.new("NoCollisionConstraint")

	c.Part0 = a
	c.Part1 = b
	c.Parent = a

	table.insert(CollisionConstraints,c)

end



-- Apply collision disabling to a character

local function disableCharacterCollision(character)

	if not Enabled then return end

	local myChar = LocalPlayer.Character
	if not myChar then return end

	local myParts = {}

	for _,p in ipairs(myChar:GetDescendants()) do
		if p:IsA("BasePart") then
			table.insert(myParts,p)
		end
	end


	for _,other in ipairs(character:GetDescendants()) do

		if other:IsA("BasePart") then

			for _,mine in ipairs(myParts) do

				createNoCollision(mine,other)

			end

		end

	end


	-- Catch late loaded accessories/layered clothing

	character.DescendantAdded:Connect(function(obj)

		if not Enabled then return end

		if obj:IsA("BasePart") then

			for _,mine in ipairs(myParts) do
				createNoCollision(mine,obj)
			end

		end

	end)

end



-- Setup every player

local function setupPlayer(plr)

	if plr == LocalPlayer then return end


	if CharacterConnections[plr] then
		CharacterConnections[plr]:Disconnect()
	end


	CharacterConnections[plr] = plr.CharacterAdded:Connect(function(char)

		-- Wait for R15 body/accessories to load

		char:WaitForChild("HumanoidRootPart",5)

		task.wait(1)


		if Enabled then
			disableCharacterCollision(char)
		end


	end)


	-- Already spawned

	if plr.Character and Enabled then

		task.spawn(function()

			plr.Character:WaitForChild("HumanoidRootPart",5)
			task.wait(1)

			disableCharacterCollision(plr.Character)

		end)

	end

end



for _,p in ipairs(Players:GetPlayers()) do
	setupPlayer(p)
end


Players.PlayerAdded:Connect(function(player)

	setupPlayer(player)

end)



Players.PlayerRemoving:Connect(function(player)

	if CharacterConnections[player] then
		CharacterConnections[player]:Disconnect()
	end

	CharacterConnections[player] = nil

end)



-- Remove fling objects

local function removeForces(part)

	for _,obj in ipairs(part:GetChildren()) do

		if obj:IsA("AlignPosition")
		or obj:IsA("AlignOrientation")
		or obj:IsA("Torque")
		or obj:IsA("AngularVelocity")
		or obj:IsA("LinearVelocity")
		or obj:IsA("VectorForce") then

			obj:Destroy()

		end

	end

end



local function protectPart(part)

	if not Enabled then return end
	if not part:IsA("BasePart") then return end
	if part.Anchored then return end
	if ProcessedParts[part] then return end


	ProcessedParts[part] = true


	removeForces(part)


	part.ChildAdded:Connect(function(obj)

		if not Enabled then return end


		if obj:IsA("AlignPosition")
		or obj:IsA("AlignOrientation")
		or obj:IsA("Torque")
		or obj:IsA("AngularVelocity")
		or obj:IsA("LinearVelocity")
		or obj:IsA("VectorForce") then

			obj:Destroy()

		end

	end)

end



Workspace.DescendantAdded:Connect(function(obj)

	if Enabled then

		task.defer(function()
			protectPart(obj)
		end)

	end

end)



-- Toggle

local function Enable()

	Enabled = true

	Button.Text = "Anti ON"

	table.clear(ProcessedParts)


	for _,obj in ipairs(Workspace:GetDescendants()) do
		protectPart(obj)
	end


	for _,p in ipairs(Players:GetPlayers()) do

		if p ~= LocalPlayer and p.Character then

			disableCharacterCollision(p.Character)

		end

	end

end



local function Disable()

	Enabled = false

	Button.Text = "Anti OFF"

	table.clear(ProcessedParts)

	clearCollision()

end



Button.MouseButton1Click:Connect(function()

	if Enabled then
		Disable()
	else
		Enable()
	end

end)



-- Velocity protection

task.spawn(function()

	while true do

		if Enabled then

			local char = LocalPlayer.Character
			local root = char and char:FindFirstChild("HumanoidRootPart")


			if root then

				for _,part in ipairs(
					Workspace:GetPartBoundsInRadius(root.Position,150)
				) do


					if part:IsA("BasePart")
					and not part.Anchored
					and not part:IsDescendantOf(char) then


						protectPart(part)


						if part.AssemblyLinearVelocity.Magnitude > VELOCITY_LIMIT then
							part.AssemblyLinearVelocity = Vector3.zero
						end


						if part.AssemblyAngularVelocity.Magnitude > ANGULAR_LIMIT then
							part.AssemblyAngularVelocity = Vector3.zero
						end

					end

				end

			end

		end


		task.wait(0.25)

	end

end)



LocalPlayer.CharacterAdded:Connect(function()

	task.wait(1)

	if Enabled then

		for _,p in ipairs(Players:GetPlayers()) do

			if p ~= LocalPlayer and p.Character then

				disableCharacterCollision(p.Character)

			end

		end

	end

end)
