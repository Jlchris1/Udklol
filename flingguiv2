-- "Start Fling All" Button Logic - Skips players with Whitelisted = true
StartButton.MouseButton1Click:Connect(function()
    if not isRunning then
        isRunning = true
        stopSignal = false
        startPos = Player.Character.HumanoidRootPart.Position -- store starting position

        -- Fire fling all loop repeatedly until stopped
        while isRunning and not stopSignal do
            for _, targetPlayer in pairs(Players:GetPlayers()) do
                -- Check stop signal between each player
                if stopSignal or not isRunning then break end
                -- Skip self, skip whitelisted players
                if targetPlayer ~= Player and not IsWhitelisted(targetPlayer) then
                    SkidFling(targetPlayer)
                end
            end
            if stopSignal or not isRunning then break end
            task.wait() -- wait before restarting the loop
        end
        -- Safety cleanup when loop ends
        SafetyReset()
    end
end)

-- "Target Selected" Button Logic - Flings all players with Selected = true
TargetSelectedButton.MouseButton1Click:Connect(function()
    if not isRunning then
        isRunning = true
        stopSignal = false
        startPos = Player.Character.HumanoidRootPart.Position -- store starting position

        -- Fire fling for selected players repeatedly until stopped
        while isRunning and not stopSignal do
            local selectedPlayers = GetSelectedPlayers()
            if #selectedPlayers > 0 then
                for _, targetPlayer in ipairs(selectedPlayers) do
                    if stopSignal or not isRunning then break end
                    SkidFling(targetPlayer)
                end
            else
                Message("No Targets", "No players have Selected = true", 3)
            end
            if stopSignal or not isRunning then break end
            task.wait() -- wait before restarting the loop
        end
        -- Safety cleanup when loop ends
        SafetyReset()
    end
end)

