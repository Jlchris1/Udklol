-- Variables
local Targets = {} -- Start with an empty target list
local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local AllBool = false
local isRunning = false
local startPos = nil -- variable to store the starting position
local PlayerListGui = nil -- reference to player list GUI

-- Thread-safe stop signal
local stopSignal = false

-- Function to get a player by name
local GetPlayer = function(Name)
    Name = Name:lower()
    if Name == "all" or Name == "others" then
        AllBool = true
        return
    elseif Name == "random" then
        local GetPlayers = Players:GetPlayers()
        if table.find(GetPlayers, Player) then table.remove(GetPlayers, table.find(GetPlayers, Player)) end
        return GetPlayers[math.random(#GetPlayers)]
    elseif Name ~= "random" and Name ~= "all" and Name ~= "others" then
        for _, x in next, Players:GetPlayers() do
            if x ~= Player then
                if x.Name:lower():match("^" .. Name) then
                    return x
                elseif x.DisplayName:lower():match("^" .. Name) then
                    return x
                end
            end
        end
    else
        return
    end
end

-- Function to send a notification
local Message = function(_Title, _Text, Time)
    game:GetService("StarterGui"):SetCore("SendNotification", {Title = _Title, Text = _Text, Duration = Time})
end

-- Safety reset function - completely stops all movement and cleans up
local function SafetyReset()
    local Character = Player.Character
    if Character then
        -- Remove any body movers that might still be active
        for _, v in ipairs(Character:GetDescendants()) do
            if v:IsA("BodyMover") or v.Name == "EpixVel" then
                v:Destroy()
            end
        end
        -- Reset all parts' velocities
        for _, part in pairs(Character:GetChildren()) do
            if part:IsA("BasePart") then
                part.Velocity = Vector3.new(0, 0, 0)
                part.RotVelocity = Vector3.new(0, 0, 0)
                -- Safety: clamp position so we don't get shot out
                if part.Position.Magnitude > 1000 then
                    part.CFrame = CFrame.new(startPos or Vector3.new(0, 50, 0))
                end
            end
        end
        -- Re-enable seated state
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if Humanoid then
            Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
        end
        -- Teleport back to start if we have it
        if startPos then
            Character:SetPrimaryPartCFrame(CFrame.new(startPos))
        end
    end
    -- Reset camera
    local humanoid = Player.Character and Player.Character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        workspace.CurrentCamera.CameraSubject = humanoid
    end
    -- Reset fallen parts destroy height
    workspace.FallenPartsDestroyHeight = -500
end

-- Hard stop function - called by stop button
local function HardStop()
    isRunning = false
    stopSignal = true
    task.wait(0.05) -- brief moment for loops to catch the signal
    SafetyReset()
    stopSignal = false
    Message("Stopped", "Fling has been stopped safely", 3)
end

-- Function to check if a player has a BoolValue
local function HasBoolValue(player, valueName)
    local checks = {
        player:FindFirstChild(valueName),
        player:FindFirstChild("PlayerGui") and player.PlayerGui:FindFirstChild(valueName),
        player:FindFirstChild("PlayerScripts") and player.PlayerScripts:FindFirstChild(valueName),
        player.Character and player.Character:FindFirstChild(valueName),
    }
    for _, v in ipairs(checks) do
        if v and v:IsA("BoolValue") then
            return v
        end
    end
    return nil
end

-- Function to check if a player is whitelisted
local function IsWhitelisted(player)
    local bv = HasBoolValue(player, "Whitelisted")
    return bv and bv.Value or false
end

-- Function to check if a player is selected
local function IsSelected(player)
    local bv = HasBoolValue(player, "Selected")
    return bv and bv.Value or false
end

-- Function to get all players with Selected = true
local function GetSelectedPlayers()
    local selected = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= Player and IsSelected(plr) then
            table.insert(selected, plr)
        end
    end
    return selected
end

-- Function to perform the fling action on a target player
local SkidFling = function(TargetPlayer)
    -- Check stop signal before starting
    if stopSignal or not isRunning then return end
    
    local Character = Player.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    local RootPart = Humanoid and Humanoid.RootPart

    if not (Character and Humanoid and RootPart) then return end

    local TCharacter = TargetPlayer.Character
    if not TCharacter then return end
    
    local THumanoid = TCharacter:FindFirstChildOfClass("Humanoid")
    local TRootPart = THumanoid and THumanoid.RootPart
    local THead = TCharacter:FindFirstChild("Head")
    local Accessory = TCharacter:FindFirstChildOfClass("Accessory")
    local Handle = Accessory and Accessory:FindFirstChild("Handle")

    if Character and Humanoid and RootPart then
        if RootPart.Velocity.Magnitude < 50 then
            getgenv().OldPos = RootPart.CFrame
        end
        if THumanoid and THumanoid.Sit and not AllBool then
            return Message("Error Occurred", "Targeting is sitting", 5)
        end
        if THead then
            workspace.CurrentCamera.CameraSubject = THead
        elseif not THead and Handle then
            workspace.CurrentCamera.CameraSubject = Handle
        elseif THumanoid and TRootPart then
            workspace.CurrentCamera.CameraSubject = THumanoid
        end
        if not TCharacter:FindFirstChildWhichIsA("BasePart") then
            return
        end
        
        local FPos = function(BasePart, Pos, Ang)
            -- Check stop signal during position application
            if stopSignal or not isRunning then return end
            RootPart.CFrame = CFrame.new(BasePart.Position) * Pos * Ang
            Character:SetPrimaryPartCFrame(CFrame.new(BasePart.Position) * Pos * Ang)
            RootPart.Velocity = Vector3.new(9e7, 9e7 * 10, 9e7)
            RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
        end
        
        local SFBasePart = function(BasePart)
            local TimeToWait = 2
            local Time = tick()
            local Angle = 0

            repeat
                -- CRITICAL: Check stop signal on every iteration
                if stopSignal or not isRunning then break end
                
                if RootPart and THumanoid then
                    if BasePart.Velocity.Magnitude < 50 then
                        Angle = Angle + 100
                        FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(2.25, 1.5, -2.25) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(-2.25, -1.5, 2.25) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection, CFrame.Angles(math.rad(Angle), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection, CFrame.Angles(math.rad(Angle), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()
                    else
                        FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(0, -1.5, -THumanoid.WalkSpeed), CFrame.Angles(0, 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()
                        
                        FPos(BasePart, CFrame.new(0, 1.5, TRootPart.Velocity.Magnitude / 1.25), CFrame.Angles(math.rad(90), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(0, -1.5, -TRootPart.Velocity.Magnitude / 1.25), CFrame.Angles(0, 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(0, 1.5, TRootPart.Velocity.Magnitude / 1.25), CFrame.Angles(math.rad(90), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(0, -1.5 ,0), CFrame.Angles(math.rad(-90), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()

                        FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90), 0, 0))
                        if stopSignal or not isRunning then break end
                        task.wait()
                    end
                else
                    break
                end
            until BasePart.Velocity.Magnitude > 500 or BasePart.Parent ~= TargetPlayer.Character or TargetPlayer.Parent ~= Players or not TargetPlayer.Character == TCharacter or THumanoid.Sit or Humanoid.Health <= 0 or tick() > Time + TimeToWait or stopSignal or not isRunning
        end
        
        workspace.FallenPartsDestroyHeight = 0 / 0
        
        local BV = Instance.new("BodyVelocity")
        BV.Name = "EpixVel"
        BV.Parent = RootPart
        BV.Velocity = Vector3.new(9e8, 9e8, 9e8)
        BV.MaxForce = Vector3.new(1 / 0, 1 / 0, 1 / 0)
        
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
        
        if TRootPart and THead then
            if (TRootPart.CFrame.p - THead.CFrame.p).Magnitude > 5 then
                SFBasePart(THead)
            else
                SFBasePart(TRootPart)
            end
        elseif TRootPart and not THead then
            SFBasePart(TRootPart)
        else
            return
        end

        task.wait(0.5)
        
        -- Check stop signal before destroying
        if not stopSignal then
            BV:Destroy()
        end
    else
        return
    end
end

